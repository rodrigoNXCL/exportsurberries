---
// Componente Footer Moderno - Estilo Enterprise 2026
---

<footer class="footer">
  <div class="container-custom">
    {/* Sección Principal */}
    <div class="footer-main">
      {/* Columna 1: Información Empresa */}
      <div class="footer-column footer-info">
        <h3 class="footer-title">Exportadora Surberries</h3>
        <p class="footer-description">
          Comercializadora y Exportadora de frutos congelados premium desde Chile para el mundo. 
          Conectamos origen, calidad y cumplimiento en cada exportación.
        </p>
        
        {/* Redes Sociales */}
        <div class="social-links">
          <a href="#" class="social-link" aria-label="Instagram">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="LinkedIn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Facebook">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
        </div>
      </div>

      {/* Columna 2: Contacto */}
      <div class="footer-column footer-contact">
        <h3 class="footer-title">Contacto</h3>
        
        <div class="contact-items">
          <a href="https://wa.me/56959008508?text=Hola,%20me%20interesa%20contactar%20a%20Surberries" 
             class="contact-item" 
             target="_blank" 
             rel="noopener noreferrer">
            <span class="contact-icon phone">📱</span>
            <span class="contact-text">+56 9 5900 8508</span>
          </a>
          
          <a href="mailto:contacto@exportsurberries.cl" class="contact-item">
            <span class="contact-icon email">📧</span>
            <span class="contact-text">contacto@exportsurberries.cl</span>
          </a>
          
          <a href="https://www.google.com/maps/search/?api=1&query=Isabel+Riquelme+506+Chill%C3%A1n+Chile" 
             class="contact-item" 
             target="_blank" 
             rel="noopener noreferrer">
            <span class="contact-icon location">📍</span>
            <span class="contact-text">Isabel Riquelme #506 - Chillán - Chile</span>
          </a>
          
        </div>
      </div>
    </div>

    {/* Separador */}
    <div class="footer-divider"></div>

    {/* Copyright */}
    <div class="footer-bottom">
      <p class="copyright">
        © {new Date().getFullYear()} Exportadora Surberries. Todos los derechos reservados.
      </p>
      <p class="credits">
        Desarrollado por <a href="https://nxchile.com" target="_blank" rel="noopener noreferrer" class="nxchile-link">nxChile</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-footer-bg);
    color: var(--color-white);
    padding: 4rem 0 2rem;
    margin-top: 0;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-title {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 0.5rem;
  }

  .footer-description {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray-300);
    max-width: 450px;
  }

  /* Redes Sociales */
  .social-links {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-full);
    color: var(--color-white);
    transition: all var(--transition-base);
  }

  .social-link:hover {
    background: var(--color-primary);
    color: var(--color-white);
    transform: translateY(-3px);
  }

  /* Contacto Items */
  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--color-gray-300);
    transition: color var(--transition-fast);
    text-decoration: none;
  }

  .contact-item:hover {
    color: var(--color-white);
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-full);
    font-size: 1.125rem;
    flex-shrink: 0;
  }

  .contact-icon.phone {
    background: rgba(34, 139, 34, 0.2);
  }

  .contact-icon.email {
    background: rgba(196, 30, 58, 0.2);
  }

  .contact-icon.location {
    background: rgba(255, 184, 0, 0.2);
  }

  .contact-text {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: inherit;
  }

  /* Separador */
  .footer-divider {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    margin: 2rem 0;
  }

  /* Copyright */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-gray-400);
  }

  .credits {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-gray-400);
  }

  .nxchile-link {
    color: var(--color-accent);
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .nxchile-link:hover {
    color: var(--color-accent-light);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer {
      padding: 3rem 0 1.5rem;
    }

    .footer-main {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .footer-description {
      max-width: 100%;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }

    .social-links {
      justify-content: center;
    }
  }

  /* Dirección clickeable */
  .contact-item[href*="maps"] {
    position: relative;
  }

  .contact-item[href*="maps"]:hover .contact-text {
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-underline-offset: 3px;
  }

  .contact-item[href*="maps"]::after {
    content: '🗺️';
    font-size: 0.75rem;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .contact-item[href*="maps"]:hover::after {
    opacity: 1;
  }

</style>