---
// Componente Header Moderno - Bilingual Support
---

<header class="header" id="header">
  <div class="container-custom">
    <div class="header-content">
      {/* Logo */}
      <a href="/" class="logo">
        <img 
          src="/images/logo-surberries.png" 
          alt="Sur Berries - Exportadora de Frutos Congelados" 
          class="logo-image"
        />
      </a>

      {/* Navegación Desktop - Dinámica según idioma */}
      <nav class="nav-desktop">
        <ul class="nav-list">
          {Astro.url.pathname.startsWith('/en/') ? (
            <>
              <li><a href="/en/" class="nav-link">Home</a></li>
              <li><a href="/en/productos" class="nav-link">Products</a></li>
              <li><a href="/en/#nosotros" class="nav-link">About Us</a></li>
              <li><a href="/en/#contacto" class="nav-link">Contact</a></li>
            </>
          ) : (
            <>
              <li><a href="/" class="nav-link">Inicio</a></li>
              <li><a href="/productos" class="nav-link">Productos</a></li>
              <li><a href="/#nosotros" class="nav-link">Nosotros</a></li>
              <li><a href="/#contacto" class="nav-link">Contacto</a></li>
            </>
          )}
        </ul>
      </nav>

      {/* Selector de Idioma + CTA - CON LINKS REALES */}
      <div class="header-actions">
        <div class="language-switcher">
          {Astro.url.pathname.startsWith('/en/') ? (
            <>
              {/* Estás en INGLÉS: ES es clickable, EN está activo */}
              <a href="/" class="lang-btn">ES</a>
              <span class="lang-separator">|</span>
              <span class="lang-btn active">EN</span>
            </>
          ) : (
            <>
              {/* Estás en ESPAÑOL: ES está activo, EN es clickable */}
              <span class="lang-btn active">ES</span>
              <span class="lang-separator">|</span>
              <a href="/en/" class="lang-btn">EN</a>
            </>
          )}
        </div>
  {/* ✅ Botón Clientes DINÁMICO */}
  <a href={Astro.url.pathname.startsWith('/en/') ? '/en/clientes' : '/clientes'} class="btn-cotizar">
  {Astro.url.pathname.startsWith('/en/') ? 'Clients' : 'Clientes'}
  </a>
      </div>

      {/* Menú Mobile Toggle */}
      <button class="mobile-toggle" id="mobileToggle" aria-label="Abrir menú">
        <span class="hamburger"></span>
      </button>
    </div>
  </div>

  {/* Menú Mobile - Dinámico según idioma */}
  <div class="nav-mobile" id="navMobile">
    <ul class="nav-mobile-list">
      {Astro.url.pathname.startsWith('/en/') ? (
        <>
          <li><a href="/en/" class="nav-mobile-link">Home</a></li>
          <li><a href="/en/productos" class="nav-mobile-link">Products</a></li>
          <li><a href="/en/#nosotros" class="nav-mobile-link">About Us</a></li>
          <li><a href="/en/#contacto" class="nav-mobile-link">Contact</a></li>
          {/* ✅ Botón Clientes en Mobile - Versión EN */}
          <li class="nav-mobile-cta">
            <a href="/en/clientes" class="btn btn-primary" style="width: 100%; justify-content: center;">
              Client Portal
            </a>
          </li>
        </>
      ) : (
        <>
          <li><a href="/" class="nav-mobile-link">Inicio</a></li>
          <li><a href="/productos" class="nav-mobile-link">Productos</a></li>
          <li><a href="/#nosotros" class="nav-mobile-link">Nosotros</a></li>
          <li><a href="/#contacto" class="nav-mobile-link">Contacto</a></li>
          <li class="nav-mobile-cta">
            <a href="/clientes" class="btn btn-primary" style="width: 100%; justify-content: center;">
              Acceso Clientes
            </a>
          </li>
        </>
      )}
    </ul>
  </div>
</header>

<script>
  // Header scroll effect
  const header = document.getElementById('header');
  const mobileToggle = document.getElementById('mobileToggle');
  const navMobile = document.getElementById('navMobile');

  // Blur effect al hacer scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('header-scrolled');
    } else {
      header?.classList.remove('header-scrolled');
    }
  });

  // Toggle menú mobile
  mobileToggle?.addEventListener('click', () => {
    navMobile?.classList.toggle('nav-mobile-active');
    mobileToggle.classList.toggle('toggle-active');
  });

  // Cerrar menú mobile al hacer click en enlace
  document.querySelectorAll('.nav-mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      navMobile?.classList.remove('nav-mobile-active');
      mobileToggle?.classList.remove('toggle-active');
    });
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: transparent;
    transition: all 0.3s ease;
  }

  .header-scrolled {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    gap: 2rem;
  }

  .header-scrolled .header-content {
    padding: 0.75rem 0;
  }

  .logo {
    display: flex;
    align-items: center;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .logo:hover {
    opacity: 0.85;
  }

  .logo-image {
    height: 90px;
    width: auto;
    object-fit: contain;
    transition: height 0.3s ease;
  }

  .header-scrolled .logo-image {
    height: 70px;
  }

  @media (max-width: 1024px) {
    .logo-image {
      height: 70px;
    }
    .header-scrolled .logo-image {
      height: 60px;
    }
    .header-content {
      padding: 1rem 0;
    }
    .header-scrolled .header-content {
      padding: 0.75rem 0;
    }
  }

  @media (max-width: 480px) {
    .logo-image {
      height: 60px;
    }
    .header-scrolled .logo-image {
      height: 55px;
    }
  }

  .nav-desktop {
    display: none;
  }

  @media (min-width: 1024px) {
    .nav-desktop {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 2.5rem;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-gray-700);
    transition: color var(--transition-fast);
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-primary);
    transition: width var(--transition-base);
  }

  .nav-link:hover {
    color: var(--color-primary);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .language-switcher {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* ✅ IMPORTANTE: Los lang-btn que SON links deben parecer botones */
  .lang-btn {
    background: none;
    border: none;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-gray-500);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    transition: color var(--transition-fast);
    text-decoration: none;
  }

  /* ✅ Cuando es un <a>, quitamos el underline por defecto */
  a.lang-btn {
    text-decoration: none;
  }

  .lang-btn:hover,
  .lang-btn.active {
    color: var(--color-primary);
  }

  .lang-separator {
    color: var(--color-gray-300);
  }

  .btn-cotizar {
    background: var(--color-primary);
    color: var(--color-white);
    padding: 0.625rem 1.5rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 0.875rem;
    transition: all var(--transition-base);
  }

  .btn-cotizar:hover {
    background: var(--color-primary-dark);
    color: var(--color-white);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .mobile-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  @media (min-width: 1024px) {
    .mobile-toggle {
      display: none;
    }
  }

  .hamburger {
    width: 24px;
    height: 2px;
    background: var(--color-gray-700);
    position: relative;
    transition: background var(--transition-fast);
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 2px;
    background: var(--color-gray-700);
    transition: transform var(--transition-base);
  }

  .hamburger::before {
    top: -8px;
  }

  .hamburger::after {
    bottom: -8px;
  }

  .toggle-active .hamburger {
    background: transparent;
  }

  .toggle-active .hamburger::before {
    transform: rotate(45deg);
    top: 0;
  }

  .toggle-active .hamburger::after {
    transform: rotate(-45deg);
    bottom: 0;
  }

  .nav-mobile {
    position: fixed;
    top: 0;
    right: -100%;
    width: 80%;
    max-width: 350px;
    height: 100vh;
    background: var(--color-white);
    box-shadow: var(--shadow-xl);
    padding: 6rem 2rem 2rem;
    transition: right var(--transition-slow);
    z-index: 999;
  }

  .nav-mobile-active {
    right: 0;
  }

  .nav-mobile-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .nav-mobile-link {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-gray-800);
    transition: color var(--transition-fast);
  }

  .nav-mobile-link:hover {
    color: var(--color-primary);
  }

  .nav-mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 998;
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-base);
  }

  .nav-mobile-overlay-active {
    opacity: 1;
    visibility: visible;
  }

  @media (max-width: 1023px) {
    .header-actions .language-switcher {
      display: flex;
    }
    
    .header-actions .btn-cotizar {
      display: none;
    }

    .mobile-toggle {
      display: flex !important;
      margin-left: 0.5rem;
      z-index: 1001;
    }

    .header-content {
      gap: 1rem;
    }

    .nav-mobile-cta {
      margin-top: 2.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--color-gray-200);
    }

    .nav-mobile-cta .btn {
      width: 100%;
      justify-content: center;
      padding: 1rem;
      font-size: 1rem;
    }
  }
</style>