---
// Componente Hero Section - Primera impresión épica - BILINGÜE
---

<section class="hero" id="inicio">
  {/* Background Image con Overlay */}
  <div class="hero-background">
    <div class="hero-overlay"></div>
    {/* Placeholder para imagen de berries - Reemplazar con imagen real */}
    <div class="hero-image-placeholder">
      <div class="berries-showcase">
        <div class="berry strawberry"></div>
        <div class="berry raspberry"></div>
        <div class="berry blueberry"></div>
        <div class="berry blackberry"></div>
      </div>
    </div>
  </div>

  {/* Contenido Principal */}
  <div class="container-custom">
    <div class="hero-content">
      <div class="hero-text fade-in-up">
        <h1 class="hero-title">
          {Astro.url.pathname.startsWith('/en/') 
            ? 'Premium Frozen Fruits' 
            : 'Frutos Congelados Premium'}
          <span class="hero-subtitle-line">
            {Astro.url.pathname.startsWith('/en/')
              ? 'From Chile to the World'
              : 'Desde Chile para el Mundo'}
          </span>
        </h1>
        
        <p class="hero-description">
          {Astro.url.pathname.startsWith('/en/')
            ? 'We export strawberries, raspberries, and blueberries of the highest quality. We connect Chilean origin with international markets, ensuring freshness, traceability, and compliance in every shipment.'
            : 'Exportamos frutillas, frambuesas y arándanos de la más alta calidad. Conectamos el origen chileno con mercados internacionales, garantizando frescura, trazabilidad y cumplimiento en cada exportación.'}
        </p>

        <div class="hero-actions">
          <a 
            href={Astro.url.pathname.startsWith('/en/') ? '/en/productos' : '/productos'} 
            class="btn btn-primary btn-lg"
          >
            <span>
              {Astro.url.pathname.startsWith('/en/') ? 'View Products' : 'Conocer Productos'}
            </span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a 
            href={Astro.url.pathname.startsWith('/en/') ? '/en/cotizar' : '/cotizar'} 
            class="btn btn-outline btn-lg"
          >
            {Astro.url.pathname.startsWith('/en/') ? 'Request a Quote' : 'Solicitar Cotización'}
          </a>
        </div>

        {/* Stats */}
        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-number">+25</div>
            <div class="stat-label">
              {Astro.url.pathname.startsWith('/en/')
                ? 'Years of experience | Bulk and Retail'
                : 'Años de experiencia | Granel y Retail'}
            </div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <div class="stat-number">+30</div>
            <div class="stat-label">
              {Astro.url.pathname.startsWith('/en/')
                ? 'Countries reached'
                : 'Países alcanzados'}
            </div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">
              {Astro.url.pathname.startsWith('/en/')
                ? 'Certified quality'
                : 'Calidad certificada'}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Scroll Indicator */}
  <div class="scroll-indicator">
    <div class="mouse">
      <div class="wheel"></div>
    </div>
    <span>Scroll</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 0 4rem;
    overflow: hidden;
  }

  /* Background */
  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(196, 30, 58, 0.85) 0%, rgba(34, 139, 34, 0.75) 100%);
    z-index: 1;
  }

  .hero-image-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    opacity: 0.1;
    z-index: 0;
  }

  /* Showcase de berries animado */
  .berries-showcase {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    opacity: 0.15;
  }

  .berry {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
  }

  .strawberry {
    width: 200px;
    height: 200px;
    background: #DC143C;
    top: 10%;
    left: 10%;
    animation: float 6s ease-in-out infinite;
  }

  .raspberry {
    width: 180px;
    height: 180px;
    background: #E30B5C;
    top: 50%;
    right: 10%;
    animation: float 7s ease-in-out infinite 1s;
  }

  .blueberry {
    width: 150px;
    height: 150px;
    background: #4169E1;
    bottom: 20%;
    left: 30%;
    animation: float 8s ease-in-out infinite 2s;
  }

  .blackberry {
    width: 160px;
    height: 160px;
    background: #2C1810;
    top: 20%;
    right: 30%;
    animation: float 6.5s ease-in-out infinite 0.5s;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-30px) rotate(5deg);
    }
  }

  /* Contenido */
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .hero-text {
    color: var(--color-white);
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--color-white);
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .hero-subtitle-line {
    display: block;
    font-size: 0.7em;
    font-weight: 600;
    color: var(--color-accent-light);
    margin-top: 0.5rem;
  }

  .hero-description {
    font-size: 1.25rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: 2.5rem;
    max-width: 650px;
  }

  /* Botones */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 4rem;
  }

  .hero-actions .btn {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .hero-actions .btn-outline {
    border-color: var(--color-white);
    color: var(--color-white);
  }

  .hero-actions .btn-outline:hover {
    background: var(--color-white);
    color: var(--color-primary);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 500;
  }

  .stat-divider {
    width: 1px;
    height: 50px;
    background: rgba(255, 255, 255, 0.3);
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-white);
    font-size: 0.875rem;
    opacity: 0.7;
    animation: bounce 2s infinite;
    z-index: 2;
  }

  .mouse {
    width: 26px;
    height: 40px;
    border: 2px solid var(--color-white);
    border-radius: 20px;
    position: relative;
  }

  .wheel {
    width: 4px;
    height: 8px;
    background: var(--color-white);
    border-radius: 2px;
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    animation: scroll 2s infinite;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateX(-50%) translateY(0);
    }
    40% {
      transform: translateX(-50%) translateY(-10px);
    }
    60% {
      transform: translateX(-50%) translateY(-5px);
    }
  }

  @keyframes scroll {
    0% {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    100% {
      opacity: 0;
      transform: translateX(-50%) translateY(15px);
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 7rem 0 3rem;
    }

    .hero-stats {
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-start;
    }

    .stat-divider {
      width: 100%;
      height: 1px;
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .btn {
      width: 100%;
    }

    .berries-showcase {
      width: 300px;
      height: 300px;
    }
  }
</style>