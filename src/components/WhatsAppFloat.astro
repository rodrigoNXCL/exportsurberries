    <a href="mailto:contacto@exportsurberries.cl" class="float-option email">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
        <polyline points="22,6 12,13 2,6"></polyline>
      </svg>
      <span>{Astro.url.pathname.startsWith('/en/') ? 'Email' : 'Email'}</span>
    </a>
    
    {/* Cotizar */}
    <a href={Astro.url.pathname.startsWith('/en/') ? '/en/cotizar' : '/cotizar'} class="float-option cotizar">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"></path>
        <rect x="9" y="3" width="6" height="4" rx="1"></rect>
        <path d="M9 12h6"></path>
        <path d="M9 16h6"></path>
      </svg>
      <span>{Astro.url.pathname.startsWith('/en/') ? 'Request Quote' : 'Cotizar'}</span>
    </a>
  </div>
</div>

<script>
  const floatBtn = document.getElementById('whatsappFloatBtn');
  const floatOptions = document.getElementById('whatsappFloatOptions');
  let isOpen = false;

  floatBtn?.addEventListener('click', () => {
    isOpen = !isOpen;
    floatOptions?.classList.toggle('active', isOpen);
    floatBtn?.classList.toggle('active', isOpen);
  });

  // Cerrar al hacer click fuera
  document.addEventListener('click', (e) => {
    if (!floatBtn?.contains(e.target) && !floatOptions?.contains(e.target)) {
      isOpen = false;
      floatOptions?.classList.remove('active');
      floatBtn?.classList.remove('active');
    }
  });

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      isOpen = false;
      floatOptions?.classList.remove('active');
      floatBtn?.classList.remove('active');
    }
  });
</script>

<style>
  .whatsapp-float-container {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 9998;
  }

  .whatsapp-float-btn {
    width: 65px;
    height: 65px;
    background: linear-gradient(135deg, #25D366 0%, #1EBE57 100%);
    border: none;
    border-radius: 50%;
    color: var(--color-white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 25px rgba(37, 211, 102, 0.4);
    transition: all 0.3s ease;
    position: relative;
  }

  .whatsapp-float-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 12px 35px rgba(37, 211, 102, 0.5);
  }

  .whatsapp-float-btn.active {
    transform: rotate(45deg);
  }

  .float-tooltip {
    position: absolute;
    right: 75px;
    background: var(--color-gray-900);
    color: var(--color-white);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .whatsapp-float-btn:hover .float-tooltip {
    opacity: 1;
    visibility: visible;
    right: 80px;
  }

  .whatsapp-float-options {
    position: absolute;
    bottom: 80px;
    right: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
    transition: all 0.3s ease;
  }

  .whatsapp-float-options.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .float-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    color: var(--color-gray-700);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.3s ease;
    min-width: 180px;
  }

  .float-option:hover {
    transform: translateX(-5px);
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.2);
  }

  .float-option.whatsapp {
    color: #25D366;
  }

  .float-option.whatsapp-intl {
    color: #128C7E;
  }

  .float-option.email {
    color: var(--color-primary);
  }

  .float-option.cotizar {
    color: var(--color-primary);
  }

  .float-option svg {
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .whatsapp-float-container {
      bottom: 1.5rem;
      right: 1.5rem;
    }

    .whatsapp-float-btn {
      width: 60px;
      height: 60px;
    }

    .float-tooltip {
      display: none;
    }

    .whatsapp-float-options {
      bottom: 75px;
    }

    .float-option {
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      min-width: 160px;
    }
  }
</style>