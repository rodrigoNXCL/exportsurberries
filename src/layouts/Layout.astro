---
interface Props {
  title: string;
  description?: string;
  lang?: 'es' | 'en';
}

const { title, description = 'Exportadora líder en frutillas, frambuesas y arándanos congelados IQF. Calidad chilena para el mundo.', lang = 'es' } = Astro.props;

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title} | Exportadora Surberries</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="frutillas congeladas, arándanos IQF, frambuesas exportación, espárragos congelados, frutas congeladas Chile, exportadora de berries" />
    <meta name="author" content="Exportadora Surberries" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://exportsurberries.cl${Astro.url.pathname}`} />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://exportsurberries.cl${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://exportsurberries.cl/images/og-image.jpg" />
    <meta property="og:locale" content={lang === 'es' ? 'es_CL' : 'en_US'} />
    <meta property="og:site_name" content="Exportadora Surberries" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={`https://exportsurberries.cl${Astro.url.pathname}`} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://exportsurberries.cl/images/og-image.jpg" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <WhatsAppFloat />

    {/*  TRACKING SCRIPT DIRECTO - SIN DEPENDENCIAS EXTERNAS */}
    <script is:inline>
      (function() {
        // 1. No trackear páginas de admin ni errores
        if (window.location.pathname.includes('/admin/') || window.location.pathname.includes('/404')) {
          return;
        }

        // 2. Enviar track DIRECTO al API (sin esperar geolocalización externa)
        // El servidor (Netlify Function) obtendrá la IP y el país internamente.
        fetch('/api/track', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            pathname: window.location.pathname,
            // Enviamos valores por defecto, el servidor los puede refinar si quiere
            country: 'Desconocido', 
            countryCode: 'XX',
            city: 'Desconocida'
          })
        })
        .then(response => {
          if (!response.ok) throw new Error('Network response was not ok');
          return response.json();
        })
        .then(data => {
          console.log('✅ Analytics registrado:', data.total);
        })
        .catch(error => {
          // Silencioso para no molestar al usuario, pero útil para debug en consola
          console.warn('️ Analytics falló (puede ser bloqueo de red):', error);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>