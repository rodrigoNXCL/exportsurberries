---
export const prerender = false;

// Importar fs de forma dinámica
import fs from 'fs/promises';
import path from 'path';

// Leer datos de analytics
let analytics = { pages: {}, total: 0, dates: {}, referrers: {} };
let hasData = false;
let errorMessage = null;

try {
  const analyticsFile = path.join(process.cwd(), 'src', 'data', 'analytics.json');
  const content = await fs.readFile(analyticsFile, 'utf-8');
  analytics = JSON.parse(content);
  hasData = Object.keys(analytics.pages || {}).length > 0;
} catch (e) {
  errorMessage = 'No hay datos de analytics disponibles aún';
  console.log('Analytics: No hay datos o archivo no existe');
}

// Calcular estadísticas
const topPages = Object.entries(analytics.pages || {})
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

const last7Days = Object.entries(analytics.dates || {})
  .sort((a, b) => b[0].localeCompare(a[0]))
  .slice(0, 7)
  .reverse();

const topReferrers = Object.entries(analytics.referrers || {})
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

const totalPages = Object.values(analytics.pages || {}).reduce((a, b) => a + b, 0) || 0;
const uniquePages = Object.keys(analytics.pages || {}).length;
const activeDays = Object.keys(analytics.dates || {}).length;
---

<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analytics Dashboard - Surberries</title>
  <style>
    :root {
      --color-primary: #7C8F4D;
      --color-primary-dark: #5a6b38;
      --color-secondary: #D4A373;
      --color-accent: #E9EDC9;
      --color-gray-50: #f9fafb;
      --color-gray-100: #f3f4f6;
      --color-gray-200: #e5e7eb;
      --color-gray-600: #4b5563;
      --color-gray-900: #111827;
      --color-white: #ffffff;
      --color-off-white: #fafafa;
      --radius-md: 0.5rem;
      --radius-lg: 0.75rem;
      --radius-xl: 1rem;
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--color-off-white);
      color: var(--color-gray-900);
      line-height: 1.6;
    }

    .admin-analytics {
      padding: 2rem 1rem 4rem;
      min-height: 100vh;
    }

    .container-custom {
      max-width: 1200px;
      margin: 0 auto;
    }

    .admin-header {
      text-align: center;
      margin-bottom: 3rem;
      padding: 2rem;
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      border-radius: var(--radius-xl);
      color: white;
    }

    .admin-header h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      font-weight: 800;
    }

    .admin-header p {
      font-size: 1.125rem;
      opacity: 0.9;
    }

    /* Login Screen */
    .login-box {
      max-width: 500px;
      margin: 4rem auto;
      background: var(--color-white);
      padding: 3rem;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-xl);
      text-align: center;
    }

    .login-icon {
      font-size: 4rem;
      margin-bottom: 1rem;
    }

    .login-box h2 {
      font-size: 1.875rem;
      margin-bottom: 1rem;
      color: var(--color-gray-900);
    }

    .login-box > p {
      color: var(--color-gray-600);
      margin-bottom: 2rem;
    }

    .password-input-group {
      display: flex;
      gap: 1rem;
      margin: 2rem 0;
      justify-content: center;
      flex-wrap: wrap;
    }

    .password-input {
      flex: 1;
      min-width: 200px;
      max-width: 300px;
      padding: 1rem;
      border: 2px solid var(--color-gray-200);
      border-radius: var(--radius-md);
      font-size: 1rem;
      text-align: center;
      transition: border-color 0.3s;
    }

    .password-input:focus {
      outline: none;
      border-color: var(--color-primary);
    }

    .login-hint {
      background: var(--color-gray-100);
      padding: 1rem;
      border-radius: var(--radius-md);
      margin: 1.5rem 0;
    }

    .login-hint small {
      color: var(--color-gray-600);
      font-size: 0.875rem;
    }

    /* Buttons */
    .btn {
      display: inline-block;
      padding: 0.875rem 2rem;
      border-radius: var(--radius-md);
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s;
      cursor: pointer;
      border: none;
      font-size: 1rem;
    }

    .btn-primary {
      background: var(--color-primary);
      color: white;
    }

    .btn-primary:hover {
      background: var(--color-primary-dark);
      transform: translateY(-2px);
    }

    .btn-outline {
      background: transparent;
      border: 2px solid var(--color-gray-200);
      color: var(--color-gray-900);
    }

    .btn-outline:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
    }

    .btn-secondary {
      background: #dc2626;
      color: white;
    }

    .btn-secondary:hover {
      background: #b91c1c;
    }

    /* Dashboard */
    #dashboard {
      display: none;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .stat-card {
      background: var(--color-white);
      padding: 2rem;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-md);
      text-align: center;
      transition: transform 0.3s;
    }

    .stat-card:hover {
      transform: translateY(-5px);
    }

    .stat-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .stat-value {
      font-size: 3rem;
      font-weight: 800;
      color: var(--color-primary);
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .stat-label {
      font-size: 1rem;
      color: var(--color-gray-600);
      font-weight: 500;
    }

    .section {
      background: var(--color-white);
      padding: 2rem;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-md);
      margin-bottom: 2rem;
    }

    .section h2 {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      color: var(--color-gray-900);
      padding-bottom: 1rem;
      border-bottom: 2px solid var(--color-gray-100);
    }

    .table-container {
      overflow-x: auto;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
    }

    .data-table th,
    .data-table td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--color-gray-200);
    }

    .data-table th {
      background: var(--color-gray-50);
      font-weight: 600;
      color: var(--color-gray-900);
      text-transform: uppercase;
      font-size: 0.875rem;
      letter-spacing: 0.05em;
    }

    .data-table tbody tr:hover {
      background: var(--color-gray-50);
    }

    .data-table code {
      background: var(--color-gray-100);
      padding: 0.25rem 0.5rem;
      border-radius: var(--radius-md);
      font-family: 'Monaco', 'Consolas', monospace;
      font-size: 0.875rem;
      color: var(--color-primary-dark);
    }

    .bar-chart {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .bar-item {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .bar-label {
      min-width: 120px;
      font-size: 0.875rem;
      color: var(--color-gray-600);
      font-family: 'Monaco', 'Consolas', monospace;
    }

    .bar-wrapper {
      flex: 1;
      height: 30px;
      background: var(--color-gray-100);
      border-radius: var(--radius-md);
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      transition: width 0.5s ease;
      border-radius: var(--radius-md);
    }

    .bar-value {
      min-width: 50px;
      font-weight: 600;
      color: var(--color-gray-900);
      text-align: right;
    }

    .admin-footer {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-top: 3rem;
      flex-wrap: wrap;
    }

    .alert {
      padding: 2rem;
      border-radius: var(--radius-lg);
      text-align: center;
      font-size: 1.125rem;
      background: #fff3cd;
      border: 2px solid #ffc107;
      color: #856404;
      margin: 2rem 0;
    }

    .alert-error {
      background: #f8d7da;
      border-color: #f5c6cb;
      color: #721c24;
    }

    @media (max-width: 768px) {
      .admin-header h1 {
        font-size: 2rem;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .password-input-group {
        flex-direction: column;
      }

      .password-input {
        max-width: 100%;
      }

      .bar-item {
        flex-direction: column;
        align-items: flex-start;
      }

      .bar-label {
        min-width: auto;
        margin-bottom: 0.5rem;
      }

      .data-table {
        font-size: 0.875rem;
      }

      .data-table th,
      .data-table td {
        padding: 0.75rem 0.5rem;
      }
    }
  </style>
</head>
<body>
  <main class="admin-analytics">
    <div class="container-custom">
      <div class="admin-header">
        <h1>📊 Analytics Dashboard</h1>
        <p>Exportadora Surberries - Estadísticas Privadas</p>
      </div>

      {/* Login Screen */}
      <div id="loginScreen" class="login-box">
        <div class="login-icon">🔐</div>
        <h2>Acceso Restringido</h2>
        <p>Ingresa la contraseña para ver las estadísticas</p>
        
        <div class="password-input-group">
          <input
            type="password"
            id="passwordInput"
            placeholder="Ingresa la contraseña..."
            class="password-input"
          />
          <button onclick="checkPassword()" class="btn btn-primary">
            Acceder
          </button>
        </div>
        
        <div class="login-hint">
          <p><small>💡 Pista: YatuSabes</small></p>
        </div>
        
        <a href="/" class="btn btn-outline">← Volver al Sitio</a>
      </div>

      {/* Dashboard */}
      <div id="dashboard">
        {errorMessage ? (
          <div class="alert alert-error">
            ⚠️ {errorMessage}
          </div>
        ) : hasData ? (
          <>
            {/* Stats Generales */}
            <div class="stats-grid">
              <div class="stat-card">
                <div class="stat-icon">👁️</div>
                <div class="stat-value">{analytics.total || 0}</div>
                <div class="stat-label">Total Pageviews</div>
              </div>
              <div class="stat-card">
                <div class="stat-icon">📄</div>
                <div class="stat-value">{uniquePages}</div>
                <div class="stat-label">Páginas Únicas</div>
              </div>
              <div class="stat-card">
                <div class="stat-icon">📅</div>
                <div class="stat-value">{activeDays}</div>
                <div class="stat-label">Días Activos</div>
              </div>
            </div>

            {/* Top Páginas */}
            <div class="section">
              <h2>🔝 Top 10 Páginas Más Visitadas</h2>
              <div class="table-container">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Página</th>
                      <th>Visitas</th>
                      <th>% del Total</th>
                    </tr>
                  </thead>
                  <tbody>
                    {topPages.map(([page, views]) => (
                      <tr>
                        <td><code>{page}</code></td>
                        <td><strong>{views}</strong></td>
                        <td>{totalPages > 0 ? ((views / totalPages) * 100).toFixed(1) : 0}%</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            {/* Fuentes de Tráfico */}
            {topReferrers.length > 0 && (
              <div class="section">
                <h2>🔗 Fuentes de Tráfico</h2>
                <div class="table-container">
                  <table class="data-table">
                    <thead>
                      <tr>
                        <th>Fuente</th>
                        <th>Visitas</th>
                      </tr>
                    </thead>
                    <tbody>
                      {topReferrers.map(([source, visits]) => (
                        <tr>
                          <td><code>{source}</code></td>
                          <td><strong>{visits}</strong></td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {/* Últimos 7 días */}
            {last7Days.length > 0 && (
              <div class="section">
                <h2>📈 Tráfico Últimos 7 Días</h2>
                <div class="bar-chart">
                  {last7Days.map(([date, views]) => {
                    const maxViews = Math.max(...last7Days.map(([,v]) => v), 1);
                    const width = (views / maxViews) * 100;
                    return (
                      <div class="bar-item">
                        <div class="bar-label">{date}</div>
                        <div class="bar-wrapper">
                          <div class="bar-fill" style={`width: ${width}%`}></div>
                        </div>
                        <div class="bar-value">{views}</div>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}
          </>
        ) : (
          <div class="alert">
            📊 No hay datos aún. Visita algunas páginas del sitio primero.
          </div>
        )}

        <div class="admin-footer">
          <button onclick="logout()" class="btn btn-outline">Cerrar Sesión</button>
          <button
            onclick="clearData()"
            class="btn btn-secondary"
          >
            🗑️ Borrar Datos
          </button>
        </div>
      </div>
    </div>
  </main>

  <script>
    // Password hardcodeada
    const ADMIN_PASSWORD = "YatuSabes";

    // Funciones globales
    window.logout = function() {
      sessionStorage.removeItem('analyticsAuth');
      location.reload();
    };

    window.checkPassword = function() {
      const input = document.getElementById('passwordInput').value;
      if (input === ADMIN_PASSWORD) {
        showDashboard();
      } else {
        alert('❌ Contraseña incorrecta');
        document.getElementById('passwordInput').value = '';
        document.getElementById('passwordInput').focus();
      }
    };

    window.clearData = async function() {
      if (confirm('¿Estás seguro de borrar todos los datos de analytics? Esta acción no se puede deshacer.')) {
        try {
          const response = await fetch('/api/clear', { method: 'POST' });
          if (response.ok) {
            alert('✅ Datos borrados correctamente');
            location.reload();
          } else {
            alert('❌ Error al borrar los datos');
          }
        } catch (error) {
          alert('❌ Error: ' + error.message);
        }
      }
    };

    function showDashboard() {
      document.getElementById('loginScreen').style.display = 'none';
      document.getElementById('dashboard').style.display = 'block';
      sessionStorage.setItem('analyticsAuth', 'true');
    }

    // Verificar autenticación al cargar
    document.addEventListener('DOMContentLoaded', function() {
      if (sessionStorage.getItem('analyticsAuth') === 'true') {
        showDashboard();
      }

      // Enter key en input
      const passwordInput = document.getElementById('passwordInput');
      if (passwordInput) {
        passwordInput.addEventListener('keypress', function(e) {
          if (e.key === 'Enter') {
            window.checkPassword();
          }
        });
        passwordInput.focus();
      }
    });
  </script>
</body>
</html>