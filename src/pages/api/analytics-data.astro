---
export const prerender = false;
import { google } from 'googleapis';
import fs from 'fs/promises';
import path from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const ROOT_DIR = path.resolve(__dirname, '..', '..', '..');

export async function GET() {
  try {
    console.log('🚀 [GA API] Iniciando...');
    
    // Cargar credenciales del Service Account
    const serviceAccountPath = path.join(ROOT_DIR, 'google-service-account.json');
    const serviceAccountContent = await fs.readFile(serviceAccountPath, 'utf-8');
    const credentials = JSON.parse(serviceAccountContent);
    
    console.log('📧 Service Account Email:', credentials.client_email);
    
    // Crear autenticación
    const auth = new google.auth.GoogleAuth({
      credentials: credentials,
      scopes: ['https://www.googleapis.com/auth/analytics.readonly'],
    });
    
    const analyticsData = google.analyticsdata({
      version: 'v1beta',
      auth: await auth.getClient(),
    });
    
    const propertyId = '396534500';
    console.log('📊 Consultando propiedad:', propertyId);
    
    // Obtener métricas principales
    const [mainReport, pagesReport, countriesReport] = await Promise.all([
      analyticsData.properties.runReport({
        property: `properties/${propertyId}`,
        dateRanges: [{ startDate: '7daysAgo', endDate: 'today' }],
        dimensions: [{ name: 'date' }],
        metrics: [
          { name: 'activeUsers' },
          { name: 'screenPageViews' },
          { name: 'sessions' },
          { name: 'averageSessionDuration' },
        ],
      }),
      analyticsData.properties.runReport({
        property: `properties/${propertyId}`,
        dateRanges: [{ startDate: '7daysAgo', endDate: 'today' }],
        dimensions: [{ name: 'pageTitle' }, { name: 'pagePath' }],
        metrics: [{ name: 'screenPageViews' }],
        orderBy: [{ metric: { metricName: 'screenPageViews' }, desc: true }],
        limit: 10,
      }),
      analyticsData.properties.runReport({
        property: `properties/${propertyId}`,
        dateRanges: [{ startDate: '7daysAgo', endDate: 'today' }],
        dimensions: [{ name: 'country' }],
        metrics: [{ name: 'activeUsers' }],
        orderBy: [{ metric: { metricName: 'activeUsers' }, desc: true }],
        limit: 10,
      }),
    ]);
    
    console.log('✅ Datos obtenidos correctamente');
    
    return new Response(JSON.stringify({
      success: true,
      data: {
        main: mainReport,
        pages: pagesReport,
        countries: countriesReport,
      }
    }), {
      status: 200,
      headers: { 'Content-Type': 'application/json' }
    });
    
  } catch (error) {
    console.error('💥 [GA API] Error:', error);
    return new Response(JSON.stringify({ 
      error: error.message, 
      success: false,
      stack: error.stack 
    }), { 
      status: 500, 
      headers: { 'Content-Type': 'application/json' } 
    });
  }
}
---