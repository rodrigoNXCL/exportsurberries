---
export const prerender = false;

export async function POST() {
  try {
    const fs = await import('fs');
    const path = await import('path');
    
    const analyticsFile = path.join(process.cwd(), 'src', 'data', 'analytics.json');
    
    // Crear archivo vacío
    const emptyData = { pages: {}, total: 0, dates: {}, referrers: {}, lastUpdate: new Date().toISOString() };
    fs.writeFileSync(analyticsFile, JSON.stringify(emptyData, null, 2), 'utf-8');

    return new Response(JSON.stringify({ success: true }), {
      status: 200,
      headers: { 'Content-Type': 'application/json' }
    });
  } catch (error) {
    console.error('Error al borrar datos:', error);
    return new Response(JSON.stringify({ error: error.message }), {
      status: 500,
      headers: { 'Content-Type': 'application/json' }
    });
  }
}
