---
export const prerender = false;

export async function POST({ request }) {
  try {
    const empty = { 
      pages: {}, 
      total: 0, 
      dates: {}, 
      referrers: {}, 
      countries: {},
      cities: {},
      lastUpdate: new Date().toISOString()
    };

    try {
      const { getStore } = await import('@netlify/blobs');
      const store = getStore('surberries_analytics');
      await store.setJSON('data', empty);
    } catch (e) {
      try {
        const fs = await import('fs');
        const path = await import('path');
        const file = path.join(process.cwd(), 'public', 'data', 'analytics.json');
        fs.writeFileSync(file, JSON.stringify(empty, null, 2), 'utf-8');
      } catch (e2) {
        console.error('⚠️ No se pudo limpiar:', e2.message);
      }
    }

    return new Response(JSON.stringify({ success: true }), {
      status: 200,
      headers: { 'Content-Type': 'application/json' }
    });
  } catch (error) {
    console.error('❌ ERROR clearing:', error);
    return new Response(JSON.stringify({ error: error.message }), {
      status: 500,
      headers: { 'Content-Type': 'application/json' }
    });
  }
}
