export const prerender = false;

export async function POST({ request }) {
  try {
    const fs = await import('fs');
    const path = await import('path');
    const analyticsFile = path.join(process.cwd(), 'src', 'data', 'analytics.json');
    
    console.log('========================================');
    console.log('🗑️ CLEARING ANALYTICS');
    console.log('========================================');
    
    const emptyData = { 
      pages: {}, 
      total: 0, 
      dates: {}, 
      referrers: {},
      countries: {},
      cities: {},
      lastUpdate: new Date().toISOString()
    };
    
    const content = JSON.stringify(emptyData, null, 2);
    fs.writeFileSync(analyticsFile, content, 'utf-8');
    
    console.log('✅ Analytics cleared successfully!');
    console.log('========================================');
    
    return new Response(JSON.stringify({ success: true }), {
      status: 200,
      headers: { 'Content-Type': 'application/json' }
    });
  } catch (error) {
    console.error('❌ ERROR clearing analytics:', error);
    return new Response(JSON.stringify({ error: error.message }), {
      status: 500,
      headers: { 'Content-Type': 'application/json' }
    });
  }
}
