---
export const prerender = false;

import { getStore } from '@netlify/blobs';

// ✅ CLAVE DEFINIDA (Fallback si no está en ENV)
const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD || "SurBerries2026!";

export async function POST({ request }) {
  try {
    // Validación básica de seguridad (opcional pero recomendada)
    const authHeader = request.headers.get('Authorization');
    const token = authHeader?.replace('Bearer ', '');
    
    if (token && token !== ADMIN_PASSWORD) {
       return new Response(JSON.stringify({ error: 'Unauthorized' }), { status: 401 });
    }

    const store = getStore({ name: 'surberries_analytics', consistency: 'strong' });
    await store.delete('data');

    return new Response(JSON.stringify({ success: true }), {
      status: 200,
      headers: { 'Content-Type': 'application/json' }
    });
  } catch (error) {
    console.error('❌ ERROR CLEAR:', error);
    return new Response(JSON.stringify({ error: error.message }), {
      status: 500,
      headers: { 'Content-Type': 'application/json' }
    });
  }
}
