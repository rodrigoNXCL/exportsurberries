export const prerender = false;

export async function POST({ request }) {
  try {
    const data = await request.json();
    const { pathname } = data;
    
    const fs = await import('fs');
    const path = await import('path');
    
    const analyticsFile = path.join(process.cwd(), 'src', 'data', 'analytics.json');
    
    console.log('========================================');
    console.log('📊 TRACKING REQUEST');
    console.log('📁 CWD:', process.cwd());
    console.log('📄 File:', analyticsFile);
    console.log('📍 Pathname:', pathname);
    console.log('========================================');
    
    let analytics = { pages: {}, total: 0, dates: {}, referrers: {} };
    
    try {
      const content = fs.readFileSync(analyticsFile, 'utf-8');
      analytics = JSON.parse(content);
      console.log('📖 Loaded:', analytics.total, 'visits');
    } catch (e) {
      console.log('📄 New file');
    }
    
    const today = new Date().toISOString().split('T')[0];
    const now = new Date().toISOString();
    
    analytics.total = (analytics.total || 0) + 1;
    analytics.pages[pathname] = (analytics.pages[pathname] || 0) + 1;
    analytics.dates[today] = (analytics.dates[today] || 0) + 1;
    analytics.lastUpdate = now;
    
    const content = JSON.stringify(analytics, null, 2);
    console.log('💾 Writing:', content);
    
    fs.writeFileSync(analyticsFile, content, 'utf-8');
    console.log('✅ WRITTEN!');
    
    const verify = fs.readFileSync(analyticsFile, 'utf-8');
    console.log('🔍 Verified:', verify);
    console.log('========================================');
    
    return new Response(JSON.stringify({ success: true, total: analytics.total }), {
      status: 200,
      headers: { 'Content-Type': 'application/json' }
    });
    
  } catch (error) {
    console.error('❌ ERROR:', error);
    return new Response(JSON.stringify({ error: error.message }), {
      status: 500,
      headers: { 'Content-Type': 'application/json' }
    });
  }
}
