---
// Página Portal de Clientes - Exportadora Surberries
// Acceso al generador de cotizaciones protegido
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portal de Clientes" description="Accede al generador de cotizaciones y área restringida para clientes." lang="es">
  
  <main class="client-portal-page">
    <div class="container-custom">
      <div class="portal-content">
        <div class="portal-header">
          <h2>Portal de Clientes</h2>
          <p>Área restringida para generación de cotizaciones profesionales y gestión de documentos.</p>
        </div>

        <div class="portal-login-card">
          <div class="login-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>

          <h3>🔐 Acceso Restringido</h3>
          <p class="login-description">
            Accede al generador de cotizaciones profesionales con los datos de Exportadora Sur Berries SpA.
            Requiere contraseña proporcionada por nuestro equipo comercial.
          </p>

          <div class="login-actions">
            {/* BOTÓN PRINCIPAL - Portal de Cotizaciones */}
            <a href="/portal" class="btn btn-primary btn-portal-access">
              🔐 Acceso Restringido
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </a>
            
            {/* Botones secundarios */}
            <a href="/cotizar" class="btn btn-outline">
              Cotización Pública
            </a>
            <a href="mailto:contacto@exportsurberries.cl" class="btn btn-outline">
              Soporte
            </a>
          </div>

          <div class="login-features">
            <div class="feature-item">
              <span class="feature-icon">📄</span>
              <span>Generar PDF profesional</span>
            </div>
            <div class="feature-item">
              <span class="feature-icon">💰</span>
              <span>USD / CLP auto-calculado</span>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🔢</span>
              <span>Correlativo automático</span>
            </div>
          </div>
          
          <p class="portal-note">
            <small>⚠️ La contraseña es confidencial. Si no la tienes, contáctanos.</small>
          </p>
        </div>
      </div>
    </div>
  </main>

</Layout>

<style>
  .client-portal-page {
    padding: 10rem 0 4rem;
    min-height: 80vh;
    background: linear-gradient(135deg, var(--color-off-white) 0%, var(--color-gray-100) 100%);
    display: flex;
    align-items: center;
  }

  .portal-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .portal-header {
    margin-bottom: 3rem;
  }

  .portal-header h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-gray-900);
  }

  .portal-header p {
    font-size: 1.125rem;
    color: var(--color-gray-600);
  }

  .portal-login-card {
    background: var(--color-white);
    border-radius: var(--radius-xl);
    padding: 3rem 2.5rem;
    box-shadow: var(--shadow-xl);
    position: relative;
    overflow: hidden;
  }

  /* Decoración sutil de "restringido" */
  .portal-login-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-primary-dark));
  }

  .login-icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }

  .login-icon svg {
    width: 64px;
    height: 64px;
  }

  .portal-login-card h3 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: var(--color-gray-900);
  }

  .login-description {
    font-size: 1rem;
    color: var(--color-gray-600);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .login-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  /* Botón de acceso restringido - Destacado */
  .btn-portal-access {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    border: none;
    box-shadow: 0 4px 15px rgba(30, 60, 30, 0.25);
    font-weight: 700;
  }

  .btn-portal-access:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(30, 60, 30, 0.35);
  }

  .login-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-gray-200);
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .feature-icon {
    font-size: 1.5rem;
  }

  .feature-item span:last-child {
    font-size: 0.875rem;
    color: var(--color-gray-600);
    font-weight: 500;
  }

  .portal-note {
    margin-top: 1.5rem;
    color: var(--color-gray-500);
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .client-portal-page {
      padding: 6rem 0 3rem;
    }

    .portal-login-card {
      padding: 2rem 1.5rem;
    }

    .login-features {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .login-actions {
      flex-direction: column;
    }

    .login-actions .btn {
      width: 100%;
    }
  }
</style>