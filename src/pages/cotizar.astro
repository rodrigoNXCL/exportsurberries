---
// Página Cotizar - Exportadora Surberries
// Formulario simple con ID único + WhatsApp + Netlify Forms
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Cotizar Productos" description="Solicita una cotización personalizada de frutillas, frambuesas y arándanos congelados IQF." lang="es">

<Header />  
  <main class="cotizar-page">
    <div class="container-custom">
      <div class="cotizar-header">
        <h2>Solicitar Cotización</h2>
        <p>Completa el formulario y te contactaremos a la brevedad. También puedes enviar directamente por WhatsApp.</p>
      </div>

      <div class="cotizar-container">
        {/* Formulario Principal */}
        <form class="cotizar-form" id="cotizarForm" name="cotizar" method="POST" data-netlify="true">
          {/* Campo oculto para Netlify Forms */}
          <input type="hidden" name="form-name" value="cotizar" />
          
          {/* Campo honeypot para spam (Netlify) */}
          <p class="hidden" style="display: none;">
            <label>
              No llenes esto si eres humano:
              <input name="bot-field" />
            </label>
          </p>

          {/* ID de Cotización (auto-generado) */}
          <div class="cotizacion-id-card">
            <span class="id-label">ID de Cotización:</span>
            <span class="id-value" id="cotizacionId">Generando...</span>
            <input type="hidden" id="cotizacionIdInput" name="cotizacion_id" />
          </div>

          <div class="form-grid">
            {/* Nombre */}
            <div class="form-group">
              <label for="nombre">Nombre *</label>
              <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
            </div>

            {/* Empresa */}
            <div class="form-group">
              <label for="empresa">Empresa *</label>
              <input type="text" id="empresa" name="empresa" required placeholder="Nombre de tu empresa" />
            </div>

            {/* Email */}
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required placeholder="tu@email.com" />
            </div>

            {/* Teléfono */}
            <div class="form-group">
              <label for="telefono">Teléfono / WhatsApp *</label>
              <input type="tel" id="telefono" name="telefono" required placeholder="+56 9 XXXX XXXX" />
            </div>

            {/* País */}
            <div class="form-group">
              <label for="pais">País de destino *</label>
              <select id="pais" name="pais" required>
                <option value="">Selecciona un país</option>
                <option value="USA">Estados Unidos</option>
                <option value="CAN">Canadá</option>
                <option value="MEX">México</option>
                <option value="BRA">Brasil</option>
                <option value="ARG">Argentina</option>
                <option value="CHN">China</option>
                <option value="ESP">España</option>
                <option value="NLD">Países Bajos</option>
                <option value="DEU">Alemania</option>
                <option value="OTH">Otro</option>
              </select>
            </div>

            {/* Producto */}
            <div class="form-group">
              <label for="producto">Producto de interés *</label>
              <select id="producto" name="producto" required>
                <option value="">Selecciona un producto</option>
                <option value="frutilla">Frutilla IQF</option>
                <option value="frambuesa">Frambuesa IQF</option>
                <option value="arandano">Arándano IQF</option>
                <option value="mix">Mix de Berries</option>
                <option value="otros">Otros frutos</option>
              </select>
            </div>

            {/* Volumen */}
            <div class="form-group">
              <label for="volumen">Volumen estimado (kg) *</label>
              <input type="number" id="volumen" name="volumen" required min="100" placeholder="Ej: 1000" />
            </div>

            {/* Fecha */}
            <div class="form-group">
              <label for="fecha">¿Cuándo lo necesitas?</label>
              <input type="date" id="fecha" name="fecha" />
            </div>
          </div>

          {/* Especificaciones */}
          <div class="form-group full-width">
            <label for="especificaciones">Especificaciones adicionales</label>
            <textarea id="especificaciones" name="especificaciones" rows="4" placeholder="Packaging, grado de congelado, certificaciones requeridas, etc."></textarea>
          </div>

          {/* Botones de envío */}
          <div class="form-actions">
            <button type="button" class="btn btn-whatsapp" id="sendWhatsApp">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Enviar por WhatsApp
            </button>
            <button type="submit" class="btn btn-outline">
              Enviar por Email
            </button>
          </div>

          {/* Mensaje de confirmación */}
          <div class="form-success" id="formSuccess" style="display: none;">
            <p>✅ ¡Cotización enviada! Te contactaremos en menos de 24 horas.</p>
            <p class="success-id">ID: <span id="successId"></span></p>
          </div>
        </form>

        {/* Info lateral */}
        <aside class="cotizar-info">
          <div class="info-card">
            <h4>¿Por qué cotizar con nosotros?</h4>
            <ul class="info-list">
              <li>✅ Respuesta en menos de 24 horas</li>
              <li>✅ Precios competitivos FOB/CIF</li>
              <li>✅ Certificaciones internacionales</li>
              <li>✅ Logística integrada</li>
              <li>✅ Soporte en español e inglés</li>
            </ul>
          </div>

          <div class="info-card highlight">
            <h4>¿Prefieres contacto directo?</h4>
            <a href="https://wa.me/56959008508?text=Hola,%20me%20interesa%20cotizar%20productos%20Surberries" 
               class="btn btn-secondary" 
               target="_blank" 
               rel="noopener noreferrer">
              WhatsApp Directo
            </a>
            <p class="info-contact">
              📧 contacto@exportsurberries.cl<br />
              📱 +56 9 5900 8508
            </p>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <script>
    // Generar ID único de cotización
    function generateCotizacionId() {
      const date = new Date();
      const dateStr = date.toISOString().slice(0, 10).replace(/-/g, ''); // YYYYMMDD
      const random = Math.random().toString(36).substring(2, 8).toUpperCase(); // 6 chars random
      return `COT-${dateStr}-${random}`;
    }

    // Inicializar ID al cargar
    const cotizacionIdEl = document.getElementById('cotizacionId');
    const cotizacionIdInput = document.getElementById('cotizacionIdInput');
    
    if (cotizacionIdEl && cotizacionIdInput) {
      const id = generateCotizacionId();
      cotizacionIdEl.textContent = id;
      cotizacionIdInput.value = id;
    }

    // Lógica del formulario
    const form = document.getElementById('cotizarForm');
    const btnWhatsApp = document.getElementById('sendWhatsApp');
    const formSuccess = document.getElementById('formSuccess');
    const successId = document.getElementById('successId');

    // Enviar por WhatsApp
    btnWhatsApp?.addEventListener('click', () => {
      const cotizacionId = cotizacionIdInput?.value || generateCotizacionId();
      const nombre = document.getElementById('nombre').value;
      const empresa = document.getElementById('empresa').value;
      const email = document.getElementById('email').value;
      const telefono = document.getElementById('telefono').value;
      const pais = document.getElementById('pais').options[document.getElementById('pais').selectedIndex]?.text || '';
      const producto = document.getElementById('producto').options[document.getElementById('producto').selectedIndex]?.text || '';
      const volumen = document.getElementById('volumen').value;
      const fecha = document.getElementById('fecha').value;
      const especificaciones = document.getElementById('especificaciones').value;

      // Validar campos requeridos
      if (!nombre || !empresa || !email || !telefono || !pais || !producto || !volumen) {
        alert('Por favor completa los campos obligatorios (*)');
        return;
      }

      // Construir mensaje formateado
      const mensaje = `🍓 *Nueva Cotización Surberries*%0A%0A` +
        `*ID Cotización:* ${cotizacionId}%0A` +
        `━━━━━━━━━━━━━━━━━━━━━━%0A%0A` +
        `*👤 Contacto:*%0A` +
        `• Nombre: ${nombre}%0A` +
        `• Empresa: ${empresa}%0A` +
        `• Email: ${email}%0A` +
        `• Teléfono: ${telefono}%0A%0A` +
        `*📦 Producto:*%0A` +
        `• Tipo: ${producto}%0A` +
        `• Volumen: ${volumen} kg%0A` +
        `• País destino: ${pais}%0A` +
        (fecha ? `• Fecha necesaria: ${fecha}%0A` : '') +
        (especificaciones ? `%0A*📝 Especificaciones:*%0A${especificaciones}%0A` : '');

      // Abrir WhatsApp
      const url = `https://wa.me/56959008508?text=${mensaje}`;
      window.open(url, '_blank');
    });

        // Enviar por Email (Netlify Forms)
    form?.addEventListener('submit', async (e) => {
      // NO prevenir default para que Netlify lo capture
      // Solo mostramos mensaje de éxito después
      
      const originalSubmit = form.submit;
      
      // Mostrar mensaje de éxito después de 500ms (tiempo para que Netlify capture)
      setTimeout(() => {
        formSuccess.style.display = 'block';
        successId.textContent = cotizacionIdInput?.value || 'N/A';
        form.reset();
        
        // Generar nuevo ID
        const newId = generateCotizacionId();
        cotizacionIdEl.textContent = newId;
        cotizacionIdInput.value = newId;

        // Ocultar mensaje después de 5 segundos
        setTimeout(() => {
          formSuccess.style.display = 'none';
        }, 5000);
      }, 500);
      
      // Permitir que el formulario se envíe naturalmente a Netlify
      // (Netlify intercepta el POST automáticamente)
    });
  </script>

  <style>
    .cotizar-page {
      padding: 10rem 0 4rem;
      background: var(--color-off-white);
      min-height: 100vh;
    }

    .cotizar-header {
      text-align: center;
      max-width: 700px;
      margin: 0 auto 4rem;
    }

    .cotizar-header h2 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: var(--color-gray-900);
    }

    .cotizar-header p {
      font-size: 1.125rem;
      color: var(--color-gray-600);
    }

    .cotizar-container {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 3rem;
      align-items: start;
    }

    .cotizar-form {
      background: var(--color-white);
      padding: 2.5rem;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
    }

    /* ID de Cotización Card */
    .cotizacion-id-card {
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      color: var(--color-white);
      padding: 1rem 1.5rem;
      border-radius: var(--radius-md);
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      font-family: var(--font-sans);
    }

    .id-label {
      font-weight: 500;
      font-size: 0.95rem;
      opacity: 0.9;
    }

    .id-value {
      font-weight: 700;
      font-size: 1.125rem;
      font-family: 'Courier New', monospace;
      letter-spacing: 1px;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-group.full-width {
      grid-column: 1 / -1;
    }

    .form-group label {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--color-gray-800);
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      padding: 0.875rem 1rem;
      border: 2px solid var(--color-gray-200);
      border-radius: var(--radius-md);
      font-family: var(--font-sans);
      font-size: 1rem;
      transition: border-color var(--transition-fast);
      background: var(--color-white);
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--color-primary);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 100px;
    }

    .form-actions {
      display: flex;
      gap: 1rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }

    .form-actions .btn {
      flex: 1;
      min-width: 200px;
    }

    .btn-whatsapp {
      background: #25D366;
      color: var(--color-white);
    }

    .btn-whatsapp:hover {
      background: #1EBE57;
      color: var(--color-white);
    }

    /* Success Message */
    .form-success {
      background: rgba(34, 139, 34, 0.1);
      border: 2px solid var(--color-secondary);
      border-radius: var(--radius-md);
      padding: 1rem 1.5rem;
      margin-top: 1.5rem;
      text-align: center;
    }

    .form-success p {
      color: var(--color-secondary-dark);
      font-weight: 600;
      margin: 0;
    }

    .success-id {
      font-family: 'Courier New', monospace;
      font-size: 0.95rem;
      margin-top: 0.5rem !important;
    }

    /* Info lateral */
    .cotizar-info {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .info-card {
      background: var(--color-white);
      padding: 2rem;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-md);
    }

    .info-card h4 {
      font-size: 1.25rem;
      margin-bottom: 1rem;
      color: var(--color-gray-900);
    }

    .info-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .info-list li {
      font-size: 0.95rem;
      color: var(--color-gray-600);
    }

/* Tarjeta destacada - Forzar colores */
.info-card.highlight {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #FFFFFF !important;  /* ← Forzar blanco */
  text-align: center;
}

.info-card.highlight h4 {
  color: #FFFFFF !important;  /* ← Forzar blanco en título */
}

.info-card.highlight p {
  color: #FFFFFF !important;  /* ← Forzar blanco en párrafos */
}

.info-card.highlight .btn {
  background: #25D366;
  color: #FFFFFF !important;
}

.info-card.highlight .btn:hover {
  background: #1EBE57;
  color: #FFFFFF !important;
}

/* Info de contacto - Forzar blanco */
.info-contact {
  font-size: 0.95rem;
  color: #FFFFFF !important;  /* ← Forzar blanco */
  opacity: 1;
  line-height: 1.6;
  font-weight: 600;  /* ← Más grueso */
}

.info-contact a {
  color: #FFFFFF !important;  /* ← Forzar blanco en links */
  text-decoration: underline;
  text-underline-offset: 3px;
}

.info-contact a:hover {
  color: #FFD44D !important;  /* ← Dorado en hover */
}

    /* Responsive */
    @media (max-width: 1024px) {
      .cotizar-container {
        grid-template-columns: 1fr;
      }

      .form-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .cotizar-page {
        padding: 6rem 0 3rem;
      }

      .cotizar-form {
        padding: 2rem 1.5rem;
      }

      .form-actions {
        flex-direction: column;
      }

      .form-actions .btn {
        width: 100%;
      }

      .cotizacion-id-card {
        flex-direction: column;
        gap: 0.5rem;
        text-align: center;
      }
    }
  </style>

</Layout>