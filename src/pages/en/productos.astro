---
// Products Page - Exportadora Surberries
// IQF Frozen Products Catalog
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Products" description="IQF frozen strawberries, blueberries, raspberries and asparagus of the highest quality. Export from Chile." lang="en">
  
  <main class="productos-page">
    <div class="container-custom">
      {/* Page Header */}
      <div class="page-header">
        <h1>Our Products</h1>
        <p>IQF (Individual Quick Frozen) fruits and vegetables of the highest quality, grown in the central valley of Chile.</p>
      </div>

      {/* Products Grid */}
      <div class="products-grid">
        {/* Product 1: Strawberries */}
        <article class="product-card" data-producto="frutilla">
          <div class="product-image-wrapper">
            <img 
              src="/images/products/frutilla-iqf.webp" 
              alt="IQF Frozen Strawberries - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Available</span>
          </div>
          
          <div class="product-info">
            <h3>IQF Strawberries</h3>
            <p class="product-subtitle">Premium Grade A</p>
            
            <ul class="product-specs">
              <li>✓ IQF (Individually Quick Frozen)</li>
              <li>✓ Boxes 10kg / 5kg</li>
              <li>✓ Brix: 8-10°</li>
              <li>✓ Season: Nov - Mar</li>
            </ul>
            
            <a href="/en/cotizar?producto=frutilla-iqf" class="btn btn-primary btn-cotizar">
              Quote Strawberries
            </a>
          </div>
        </article>

        {/* Product 2: Blueberries */}
        <article class="product-card" data-producto="arandano">
          <div class="product-image-wrapper">
            <img 
              src="/images/products/arandano-iqf.webp" 
              alt="IQF Frozen Blueberries - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Available</span>
          </div>
          
          <div class="product-info">
            <h3>IQF Blueberries</h3>
            <p class="product-subtitle">Caliber 14-18mm</p>
            
            <ul class="product-specs">
              <li>✓ IQF (Individually Quick Frozen)</li>
              <li>✓ Boxes 10kg / 2.5kg</li>
              <li>✓ Varieties: Biloxi, O'Neal</li>
              <li>✓ Season: Oct - Feb</li>
            </ul>
            
            <a href="/en/cotizar?producto=arandano-iqf" class="btn btn-primary btn-cotizar">
              Quote Blueberries
            </a>
          </div>
        </article>

        {/* Product 3: Raspberries */}
        <article class="product-card" data-producto="frambuesa">
          <div class="product-image-wrapper">
            <img 
              src="/images/products/frambuesa-iqf.webp" 
              alt="IQF Frozen Raspberries - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Available</span>
          </div>
          
          <div class="product-info">
            <h3>IQF Raspberries</h3>
            <p class="product-subtitle">Summer / Fall</p>
            
            <ul class="product-specs">
              <li>✓ IQF (Individually Quick Frozen)</li>
              <li>✓ Boxes 10kg / 5kg</li>
              <li>✓ Premium Grade</li>
              <li>✓ Season: Dec - Mar</li>
            </ul>
            
            <a href="/en/cotizar?producto=frambuesa-iqf" class="btn btn-primary btn-cotizar">
              Quote Raspberries
            </a>
          </div>
        </article>

        {/* Product 4: Asparagus */}
        <article class="product-card" data-producto="esparrago">
          <div class="product-image-wrapper">
            <img 
              src="/images/products/esparrago-iqf.webp" 
              alt="IQF Frozen Asparagus - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge limited">Season Closed</span>
          </div>
          
          <div class="product-info">
            <h3>IQF Asparagus</h3>
            <p class="product-subtitle">Green / White</p>
            
            <ul class="product-specs">
              <li>✓ IQF (Tips / Whole)</li>
              <li>✓ Boxes 10kg / Bundles</li>
              <li>✓ Caliber: S / M / L</li>
              <li>✓ Season: Aug - Nov</li>
            </ul>
            
            <a href="/en/cotizar?producto=esparrago-iqf" class="btn btn-primary btn-cotizar">
              Quote Asparagus
            </a>
          </div>
        </article>

        {/* Product 5: Other Products */}
        <article class="product-card product-card-others" data-producto="otros">
          <div class="product-image-wrapper">
            <img 
              src="/images/products/otros-productos.webp" 
              alt="Other Frozen Products - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
          </div>
          
          <div class="product-info">
            <h3>Looking for another product?</h3>
            <p class="product-subtitle">We have more options</p>
            
            <ul class="product-specs">
              <li>🫐 IQF Blackberries</li>
              <li>🍓 Berries Mix</li>
              <li>🥬 IQF Spinach</li>
              <li>🥦 IQF Broccoli</li>
            </ul>
            
            <a href="/en/cotizar" class="btn btn-outline btn-cotizar">
              Check Availability
            </a>
          </div>
        </article>
      </div>

      {/* Final CTA */}
      <div class="productos-cta">
        <h2>Need a personalized quote?</h2>
        <p>Contact us and we'll send you a proposal tailored to your needs.</p>
        <div class="cta-buttons">
          <a href="/en/cotizar" class="btn btn-primary btn-lg">
            Request a Quote
          </a>
          <a href="https://wa.me/56959008508" class="btn btn-secondary btn-lg" target="_blank" rel="noopener noreferrer">
            Direct WhatsApp
          </a>
        </div>
      </div>
    </div>
  </main>

  <style>
    .productos-page {
      padding: 10rem 0 4rem;
      background: var(--color-off-white);
      min-height: 100vh;
    }

    .page-header {
      text-align: center;
      max-width: 800px;
      margin: 0 auto 4rem;
    }

    .page-header h1 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: var(--color-gray-900);
    }

    .page-header p {
      font-size: 1.125rem;
      color: var(--color-gray-600);
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .product-card {
      background: var(--color-white);
      border-radius: var(--radius-xl);
      overflow: hidden;
      box-shadow: var(--shadow-md);
      transition: all var(--transition-base);
      display: flex;
      flex-direction: column;
    }

    .product-card:hover {
      transform: translateY(-10px);
      box-shadow: var(--shadow-2xl);
    }

    .product-image-wrapper {
      position: relative;
      height: 300px;
      overflow: hidden;
      background: linear-gradient(135deg, var(--color-gray-100) 0%, var(--color-gray-200) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .product-image {
      width: 100%;
      height: 100%;
      object-fit: contain;
      transition: transform var(--transition-base);
    }

    .product-card:hover .product-image {
      transform: scale(1.05);
    }

    .season-badge {
      position: absolute;
      top: 1rem;
      right: 1rem;
      padding: 0.5rem 1rem;
      border-radius: var(--radius-full);
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--color-white);
      z-index: 1;
    }

    .season-badge.available {
      background: var(--color-secondary);
    }

    .season-badge.limited {
      background: var(--color-primary);
    }

    .product-info {
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      flex: 1;
    }

    .product-info h3 {
      font-size: 1.5rem;
      color: var(--color-gray-900);
      margin: 0;
    }

    .product-subtitle {
      font-size: 1rem;
      color: var(--color-gray-500);
      margin: 0;
      font-weight: 500;
    }

    .product-specs {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .product-specs li {
      font-size: 0.95rem;
      color: var(--color-gray-600);
    }

    .btn-cotizar {
      margin-top: auto;
      width: 100%;
      justify-content: center;
    }

    /* Card "Other Products" - Different Style */
    .product-card-others {
      background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
      color: var(--color-white);
    }

    .product-card-others .product-info h3,
    .product-card-others .product-subtitle,
    .product-card-others .product-specs li {
      color: var(--color-white);
    }

    .product-card-others .btn-outline {
      border-color: var(--color-white);
      color: var(--color-white);
    }

    .product-card-others .btn-outline:hover {
      background: var(--color-white);
      color: var(--color-primary);
    }

    /* Final CTA */
    .productos-cta {
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      color: var(--color-white);
      padding: 4rem 3rem;
      border-radius: var(--radius-xl);
      text-align: center;
      margin-top: 4rem;
    }

    .productos-cta h2 {
      font-size: 2rem;
      margin-bottom: 1rem;
      color: var(--color-white);
    }

    .productos-cta p {
      font-size: 1.125rem;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 2rem;
    }

    .cta-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .products-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .productos-page {
        padding: 8rem 0 3rem;
      }

      .products-grid {
        grid-template-columns: 1fr;
      }

      .page-header h1 {
        font-size: 2rem;
      }

      .productos-cta {
        padding: 3rem 2rem;
      }

      .cta-buttons {
        flex-direction: column;
      }

      .cta-buttons .btn {
        width: 100%;
      }
    }
  </style>

</Layout>