// Versión Español
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Inicio" description="Exportadora líder en frutillas, frambuesas y arándanos congelados IQF. Calidad chilena para el mundo." lang="es">
  
  <div style="display: contents">
    <Header />
    <Hero />
    
    {/* Placeholder para próximas secciones - Secciones en desarrollo */}
    <section class="section" id="productos" style="min-height: 50vh; display: flex; align-items: center; justify-content: center; background: var(--color-off-white);">
      <div class="container-custom text-center">
        <h2 style="margin-bottom: 1rem;">Productos</h2>
        <p>Sección de productos en desarrollo...</p>
        <a href="/cotizar" class="btn btn-primary" style="margin-top: 1.5rem;">
          Solicitar Cotización
        </a>
      </div>
    </section>
  </div>
  
</Layout>