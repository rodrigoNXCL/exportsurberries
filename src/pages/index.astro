---
// Página de Inicio - Exportadora Surberries
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Inicio" description="Exportadora líder en frutillas, frambuesas y arándanos congelados IQF." lang="es">
  
  <div style="display: contents">
    <Header />
    <Hero />
    
    {/* =========================================
        SECCIÓN PRODUCTOS (DESPUÉS DEL HERO)
        ========================================= */}
    <section class="productos-preview-section" id="productos">
      <div class="container-custom">
        <div class="section-header">
          <span class="section-badge">Catálogo</span>
          <h2>Nuestros Productos</h2>
          <p>Frutas y verduras congeladas IQF de la más alta calidad, cultivadas en el valle central de Chile.</p>
        </div>
        
        <div class="products-preview">
          <div class="preview-card">
            <img src="/images/products/frutilla-iqf.webp" alt="Frutillas IQF" class="preview-image" />
            <h3>Frutillas IQF</h3>
          </div>
          <div class="preview-card">
            <img src="/images/products/arandano-iqf.webp" alt="Arándanos IQF" class="preview-image" />
            <h3>Arándanos IQF</h3>
          </div>
          <div class="preview-card">
            <img src="/images/products/frambuesa-iqf.webp" alt="Frambuesas IQF" class="preview-image" />
            <h3>Frambuesas IQF</h3>
          </div>
          <div class="preview-card">
            <img src="/images/products/esparrago-iqf.webp" alt="Espárragos IQF" class="preview-image" />
            <h3>Espárragos IQF</h3>
          </div>
        </div>
        
        <div class="section-cta-centered">
          <a href="/productos" class="btn btn-primary btn-lg">
            Ver Todos los Productos
          </a>
        </div>
      </div>
    </section>
    
    {/* =========================================
        SECCIÓN NOSOTROS + TRAYECTORIA
        ========================================= */}
    <section class="nosotros-section" id="nosotros">
      <div class="container-custom">
        {/* Header de Nosotros */}
        <div class="nosotros-header">
          <span class="section-badge">Sobre Nosotros</span>
          <h2>Comercializadora y Exportadora de Frutos Congelados Premium</h2>
          <p class="nosotros-subtitle">
            Conectamos origen, calidad y cumplimiento en cada exportación desde Chile al mundo.
          </p>
        </div>
        
        {/* Stats Cards */}
        <div class="nosotros-stats">
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="16" stroke="currentColor" stroke-width="2.5"/>
                <path d="M20 12V20L25 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="stat-info">
              <span class="stat-value">10+</span>
              <span class="stat-label">Años de experiencia por profesional</span>
            </div>
          </div>
          
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="16" stroke="currentColor" stroke-width="2.5"/>
                <path d="M20 14C16.686 14 14 16.686 14 20C14 23.314 16.686 26 20 26C23.314 26 26 23.314 26 20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <circle cx="20" cy="20" r="3" fill="currentColor"/>
              </svg>
            </div>
            <div class="stat-info">
              <span class="stat-value">30+</span>
              <span class="stat-label">Países alcanzados</span>
            </div>
          </div>
          
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <path d="M20 4L24 14L35 14L26 21L30 32L20 25L10 32L14 21L5 14L16 14L20 4Z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="stat-info">
              <span class="stat-value">100%</span>
              <span class="stat-label">Compromiso con la calidad</span>
            </div>
          </div>
        </div>
        
        {/* Grid Principal con Imágenes y Contenido */}
        <div class="nosotros-grid">
          {/* Columna Imágenes */}
          <div class="nosotros-images">
            <div class="image-card-large">
              <img src="/images/nosotros-main.webp" alt="Exportadora Surberries" />
              <div class="image-card-overlay">
                <span>Trayectoria y Experiencia</span>
              </div>
            </div>
            
            <div class="image-cards-small">
              <div class="image-card-small">
                <img src="/images/proceso-1.webp" alt="Control de Calidad" />
                <div class="image-card-overlay">
                  <span>Calidad</span>
                </div>
              </div>
              <div class="image-card-small">
                <img src="/images/proceso-2.webp" alt="Almacenamiento" />
                <div class="image-card-overlay">
                  <span>Almacenamiento</span>
                </div>
              </div>
              <div class="image-card-small">
                <img src="/images/proceso-3.webp" alt="Logística" />
                <div class="image-card-overlay">
                  <span>Logística</span>
                </div>
              </div>
            </div>
          </div>
          
          {/* Columna Contenido */}
          <div class="nosotros-content">
            <div class="content-block">
              <h3>Nuestra Trayectoria</h3>
              <p class="lead">
                Somos un equipo de profesionales con más de 10 años de experiencia individual 
                en la industria de exportación de frutas y verduras congeladas.
              </p>
              <p>
                Exportadora Surberries nace como una alianza estratégica de expertos en comercio exterior, 
                logística internacional y control de calidad, uniendo nuestras trayectorias para ofrecer 
                un servicio premium desde Chile al mundo.
              </p>
            </div>
            
            <div class="pilares">
              <div class="pilar-item">
                <span class="pilar-number">01</span>
                <div class="pilar-text">
                  <h4>Calidad Certificada</h4>
                  <p>Productos bajo estándares HACCP, FDA y BRC. Certificaciones internacionales que garantizan inocuidad.</p>
                </div>
              </div>
              
              <div class="pilar-item">
                <span class="pilar-number">02</span>
                <div class="pilar-text">
                  <h4>Origen Trazable</h4>
                  <p>Relación directa con productores certificados. Conocemos cada etapa del proceso productivo.</p>
                </div>
              </div>
              
              <div class="pilar-item">
                <span class="pilar-number">03</span>
                <div class="pilar-text">
                  <h4>Logística Integral</h4>
                  <p>Cadena de frío garantizada desde origen hasta destino. Coordinación puerto-a-puerto.</p>
                </div>
              </div>
            </div>
            
            <div class="nosotros-cta">
              <h3>¿Listo para trabajar con nosotros?</h3>
              <p>Contáctanos y descubre por qué somos el partner ideal para tu negocio.</p>
              <div class="cta-buttons">
                <a href="/cotizar" class="btn btn-primary btn-lg">
                  Solicitar Cotización
                </a>
                <a href="#contacto" class="btn btn-outline btn-lg">
                  Contáctanos
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    {/* =========================================
        LIGHTBOX MODAL PARA IMÁGENES
        ========================================= */}
    <div class="lightbox-modal" id="lightboxModal">
      <div class="lightbox-overlay" id="lightboxOverlay"></div>
      <div class="lightbox-content">
        <button class="lightbox-close" id="lightboxClose">&times;</button>
        <img src="" alt="" class="lightbox-image" id="lightboxImage" />
        <div class="lightbox-caption" id="lightboxCaption"></div>
        <button class="lightbox-nav lightbox-prev" id="lightboxPrev">&#10094;</button>
        <button class="lightbox-nav lightbox-next" id="lightboxNext">&#10095;</button>
      </div>
    </div>
    
    {/* Contacto Placeholder */}
    <section class="contacto-section" id="contacto">
      <div class="container-custom text-center">
        <h2>Contacto</h2>
        <p>Sección en desarrollo...</p>
      </div>
    </section>
  </div>
  
    <script>
    // Lightbox para imágenes de proceso - VERSIÓN CORREGIDA
    document.addEventListener('DOMContentLoaded', () => {
      const lightboxModal = document.getElementById('lightboxModal');
      const lightboxOverlay = document.getElementById('lightboxOverlay');
      const lightboxClose = document.getElementById('lightboxClose');
      const lightboxImage = document.getElementById('lightboxImage');
      const lightboxCaption = document.getElementById('lightboxCaption');
      const lightboxPrev = document.getElementById('lightboxPrev');
      const lightboxNext = document.getElementById('lightboxNext');
      
      const processImages = document.querySelectorAll('.image-card-small img');
      let currentIndex = 0;
      const images = [];
      
      // Verificar que existen los elementos
      if (!lightboxModal) {
        console.warn('Lightbox modal no encontrado');
        return;
      }
      
      // Colectar imágenes
      processImages.forEach((img, index) => {
        const caption = img.nextElementSibling?.querySelector('span')?.textContent || '';
        images.push({
          src: img.src,
          alt: img.alt,
          caption: caption
        });
        
        img.style.cursor = 'pointer';
        img.addEventListener('click', () => openLightbox(index));
      });
      
      if (images.length === 0) {
        console.warn('No se encontraron imágenes para el lightbox');
        return;
      }
      
      function openLightbox(index) {
        currentIndex = index;
        updateLightbox();
        lightboxModal.classList.add('active');
        document.body.style.overflow = 'hidden';
        console.log('Lightbox abierto, imagen:', currentIndex);
      }
      
      function closeLightbox() {
        lightboxModal.classList.remove('active');
        document.body.style.overflow = '';
        console.log('Lightbox cerrado');
      }
      
      function updateLightbox() {
        const img = images[currentIndex];
        if (lightboxImage) lightboxImage.src = img.src;
        if (lightboxImage) lightboxImage.alt = img.alt;
        if (lightboxCaption) lightboxCaption.textContent = img.caption;
      }
      
      function showPrev() {
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        updateLightbox();
      }
      
      function showNext() {
        currentIndex = (currentIndex + 1) % images.length;
        updateLightbox();
      }
      
      // Event Listeners con verificación
      if (lightboxClose) {
        lightboxClose.addEventListener('click', closeLightbox);
      }
      
      if (lightboxOverlay) {
        lightboxOverlay.addEventListener('click', closeLightbox);
      }
      
      if (lightboxPrev) {
        lightboxPrev.addEventListener('click', showPrev);
      }
      
      if (lightboxNext) {
        lightboxNext.addEventListener('click', showNext);
      }
      
      // Teclado
      document.addEventListener('keydown', (e) => {
        if (!lightboxModal.classList.contains('active')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') showPrev();
        if (e.key === 'ArrowRight') showNext();
      });
    });
  </script>

  <style>
    /* =========================================
       PRODUCTOS PREVIEW
       ========================================= */
    .productos-preview-section {
      padding: var(--section-padding);
      background: var(--color-off-white);
    }

    .section-header {
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
    }

    .section-badge {
      display: inline-block;
      padding: 0.5rem 2rem;
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      color: var(--color-white);
      border-radius: var(--radius-full);
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .section-header h2 {
      font-size: clamp(2rem, 4vw, 2.5rem);
      margin-bottom: 1rem;
      color: var(--color-gray-900);
    }

    .section-header p {
      font-size: 1.125rem;
      color: var(--color-gray-600);
      line-height: 1.7;
    }

    .products-preview {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      margin: 3rem 0;
    }

    .preview-card {
      background: var(--color-white);
      padding: 2.5rem 2rem;
      border-radius: var(--radius-xl);
      text-align: center;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      transition: all 0.3s ease;
    }

    .preview-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    }

    .preview-image {
      width: 160px;
      height: 160px;
      object-fit: contain;
      margin-bottom: 1.25rem;
    }

    .preview-card h3 {
      font-size: 1.25rem;
      color: var(--color-gray-900);
      margin: 0;
      font-weight: 600;
    }

    .section-cta-centered {
      text-align: center;
      margin-top: 3.5rem;
    }

    /* =========================================
       NOSOTROS SECTION
       ========================================= */
    .nosotros-section {
      padding: var(--section-padding);
      background: var(--color-white);
    }

    .nosotros-header {
      text-align: center;
      max-width: 900px;
      margin: 0 auto 4rem;
    }

    .nosotros-header h2 {
      font-size: clamp(2rem, 4vw, 2.75rem);
      margin-bottom: 1rem;
      color: var(--color-gray-900);
      line-height: 1.2;
    }

    .nosotros-subtitle {
      font-size: 1.25rem;
      color: var(--color-gray-600);
      line-height: 1.7;
      max-width: 700px;
      margin: 0 auto;
    }

    /* Stats Cards */
    .nosotros-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-bottom: 5rem;
      max-width: 1000px;
      margin-left: auto;
      margin-right: auto;
    }

    .stat-card {
      background: var(--color-white);
      border: 2px solid var(--color-gray-100);
      border-radius: var(--radius-xl);
      padding: 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      transition: all 0.3s ease;
    }

    .stat-card:hover {
      border-color: var(--color-primary);
      box-shadow: 0 8px 30px rgba(184, 26, 56, 0.1);
      transform: translateY(-5px);
    }

    .stat-icon {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      border-radius: var(--radius-lg);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-white);
      flex-shrink: 0;
    }

    .stat-info {
      display: flex;
      flex-direction: column;
    }

    .stat-value {
      font-size: 2.25rem;
      font-weight: 700;
      color: var(--color-gray-900);
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .stat-label {
      font-size: 0.95rem;
      color: var(--color-gray-600);
      line-height: 1.4;
    }

    /* Grid Principal */
    .nosotros-grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 4rem;
      align-items: start;
    }

    /* Columna Imágenes */
    .nosotros-images {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .image-card-large {
      position: relative;
      border-radius: var(--radius-xl);
      overflow: hidden;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    }

    .image-card-large img {
      width: 100%;
      height: 450px;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .image-card-large:hover img {
      transform: scale(1.05);
    }

    .image-card-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.85), transparent);
      padding: 4rem 2rem 1.5rem;
      color: var(--color-white);
      font-size: 1.125rem;
      font-weight: 600;
      text-align: center;
    }

    .image-cards-small {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .image-card-small {
      position: relative;
      border-radius: var(--radius-lg);
      overflow: hidden;
      aspect-ratio: 1;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }

    .image-card-small img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .image-card-small:hover img {
      transform: scale(1.1);
    }

    .image-card-small .image-card-overlay {
      padding: 2.5rem 0.5rem 0.75rem;
      font-size: 0.8rem;
    }

    /* Columna Contenido */
    .nosotros-content {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }

    .content-block h3 {
      font-size: 1.75rem;
      margin-bottom: 1.5rem;
      color: var(--color-gray-900);
    }

    .content-block .lead {
      font-size: 1.125rem;
      color: var(--color-gray-700);
      line-height: 1.8;
      margin-bottom: 1.25rem;
      font-weight: 500;
    }

    .content-block p {
      font-size: 1rem;
      color: var(--color-gray-600);
      line-height: 1.8;
      margin-bottom: 1rem;
    }

    /* Pilares */
    .pilares {
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
    }

    .pilar-item {
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
      padding: 1.5rem;
      background: var(--color-off-white);
      border-radius: var(--radius-lg);
      border-left: 4px solid var(--color-primary);
      transition: all 0.3s ease;
    }

    .pilar-item:hover {
      background: var(--color-gray-100);
      transform: translateX(8px);
    }

    .pilar-number {
      font-size: 0.875rem;
      font-weight: 700;
      color: var(--color-primary);
      opacity: 0.7;
      flex-shrink: 0;
      padding-top: 0.25rem;
    }

    .pilar-text h4 {
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
      color: var(--color-gray-900);
      font-weight: 600;
    }

    .pilar-text p {
      font-size: 0.95rem;
      color: var(--color-gray-600);
      line-height: 1.7;
      margin: 0;
    }

    /* CTA Box */
    .nosotros-cta {
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      color: var(--color-white);
      padding: 3rem 2.5rem;
      border-radius: var(--radius-xl);
      text-align: center;
    }

    .nosotros-cta h3 {
      font-size: 1.75rem;
      margin-bottom: 1rem;
      color: var(--color-white);
    }

    .nosotros-cta p {
      font-size: 1.125rem;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 2rem;
    }

    .cta-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .cta-buttons .btn {
      min-width: 220px;
    }

    .btn-outline {
      background: transparent;
      border: 2px solid var(--color-white);
      color: var(--color-white);
    }

    .btn-outline:hover {
      background: var(--color-white);
      color: var(--color-primary);
    }

    /* =========================================
       LIGHTBOX MODAL - CORREGIDO
       ========================================= */
    .lightbox-modal {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      pointer-events: none;
    }

    .lightbox-modal.active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .lightbox-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(5px);
    }

    .lightbox-content {
      position: relative;
      z-index: 1;
      max-width: 90vw;
      max-height: 90vh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .lightbox-image {
      max-width: 100%;
      max-height: 80vh;
      object-fit: contain;
      border-radius: var(--radius-lg);
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
      animation: lightboxZoomIn 0.3s ease;
    }

    @keyframes lightboxZoomIn {
      from {
        transform: scale(0.9);
        opacity: 0;
      }
      to {
        transform: scale(1);
        opacity: 1;
      }
    }

    .lightbox-caption {
      color: var(--color-white);
      font-size: 1.125rem;
      font-weight: 600;
      margin-top: 1rem;
      text-align: center;
    }

    .lightbox-close {
      position: absolute;
      top: -50px;
      right: 0;
      background: none;
      border: none;
      color: var(--color-white);
      font-size: 3rem;
      cursor: pointer;
      transition: color 0.3s ease;
      line-height: 1;
      z-index: 2;
    }

    .lightbox-close:hover {
      color: var(--color-primary);
    }

    .lightbox-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(255, 255, 255, 0.1);
      border: none;
      color: var(--color-white);
      font-size: 2.5rem;
      cursor: pointer;
      padding: 1rem 1.5rem;
      border-radius: var(--radius-lg);
      transition: all 0.3s ease;
      backdrop-filter: blur(10px);
      z-index: 2;
    }

    .lightbox-nav:hover {
      background: rgba(255, 255, 255, 0.2);
      color: var(--color-primary);
    }

    .lightbox-prev {
      left: -80px;
    }

    .lightbox-next {
      right: -80px;
    }

    /* Responsive Lightbox */
    @media (max-width: 1024px) {
      .lightbox-prev {
        left: 10px;
      }

      .lightbox-next {
        right: 10px;
      }

      .lightbox-close {
        top: 10px;
        right: 10px;
        font-size: 2.5rem;
      }
    }

    @media (max-width: 768px) {
      .lightbox-nav {
        padding: 0.5rem 1rem;
        font-size: 2rem;
      }

      .lightbox-prev {
        left: 5px;
      }

      .lightbox-next {
        right: 5px;
      }
    }

    /* Contacto */
    .contacto-section {
      padding: var(--section-padding);
      background: var(--color-off-white);
    }

    .text-center {
      text-align: center;
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .products-preview {
