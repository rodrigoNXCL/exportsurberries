---
// Página de Inicio - Exportadora Surberries
// Versión Español
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Inicio" description="Exportadora líder en frutillas, frambuesas y arándanos congelados IQF. Calidad chilena para el mundo." lang="es">
  
  {/* Override del header - Layout ya incluye Header, pero lo manejamos aquí para control total */}
  <div style="display: contents">
    <Header />
    <Hero />
    
    {/* Placeholder para próximas secciones */}
    <section class="section" style="min-height: 50vh; display: flex; align-items: center; justify-content: center; background: var(--color-off-white);">
      <div class="container-custom text-center">
        <h2 style="margin-bottom: 1rem;">Próximamente</h2>
        <p>Secciones de Productos, Nosotros y Contacto en desarrollo...</p>
      </div>
    </section>
  </div>
  
</Layout>