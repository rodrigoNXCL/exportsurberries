---
// Página de Inicio - Exportadora Surberries
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Inicio" description="Exportadora líder en frutillas, frambuesas y arándanos congelados IQF." lang="es">
  
  <div style="display: contents">
    
    <Hero />
    
    {/* =========================================
        SECCIÓN PRODUCTOS (DESPUÉS DEL HERO)
        ========================================= */}
    <section class="productos-preview-section" id="productos">
      <div class="container-custom">
        <div class="section-header">
          <span class="section-badge">Catálogo</span>
          <h2>Nuestros Productos</h2>
          <p>Frutas y verduras congeladas IQF de la más alta calidad, cultivadas en el valle central de Chile.</p>
        </div>
        
        <div class="products-preview">
          <div class="preview-card">
            <img src="/images/products/frutilla-iqf.webp" alt="Frutillas IQF" class="preview-image" />
            <h3>Frutillas IQF</h3>
          </div>
          <div class="preview-card">
            <img src="/images/products/arandano-iqf.webp" alt="Arándanos IQF" class="preview-image" />
            <h3>Arándanos IQF</h3>
          </div>
          <div class="preview-card">
            <img src="/images/products/frambuesa-iqf.webp" alt="Frambuesas IQF" class="preview-image" />
            <h3>Frambuesas IQF</h3>
          </div>
          <div class="preview-card">
            <img src="/images/products/esparrago-iqf.webp" alt="Espárragos IQF" class="preview-image" />
            <h3>Espárragos IQF</h3>
          </div>
        </div>
        
        <div class="section-cta-centered">
          <a href="/productos" class="btn btn-primary btn-lg">
            Ver Todos los Productos
          </a>
        </div>
      </div>
    </section>
    
    {/* =========================================
        SECCIÓN NOSOTROS + TRAYECTORIA
        ========================================= */}
    <section class="nosotros-section" id="nosotros">
      <div class="container-custom">
        {/* Header de Nosotros */}
        <div class="nosotros-header">
          <span class="section-badge">Sobre Nosotros</span>
          <h2>Comercializadora y Exportadora de Frutos Congelados Premium</h2>
          <p class="nosotros-subtitle">
            Conectamos origen, calidad y cumplimiento en cada exportación desde Chile al mundo.
          </p>
        </div>
        
        {/* Stats Cards */}
        <div class="nosotros-stats">
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="16" stroke="currentColor" stroke-width="2.5"/>
                <path d="M20 12V20L25 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="stat-info">
              <span class="stat-value">10+</span>
              <span class="stat-label">Años de experiencia por profesional</span>
            </div>
          </div>
          
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="16" stroke="currentColor" stroke-width="2.5"/>
                <path d="M20 14C16.686 14 14 16.686 14 20C14 23.314 16.686 26 20 26C23.314 26 26 23.314 26 20" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <circle cx="20" cy="20" r="3" fill="currentColor"/>
              </svg>
            </div>
            <div class="stat-info">
              <span class="stat-value">30+</span>
              <span class="stat-label">Países alcanzados</span>
            </div>
          </div>
          
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <path d="M20 4L24 14L35 14L26 21L30 32L20 25L10 32L14 21L5 14L16 14L20 4Z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="stat-info">
              <span class="stat-value">100%</span>
              <span class="stat-label">Compromiso con la calidad</span>
            </div>
          </div>
        </div>
        
        {/* Grid Principal con Imágenes y Contenido */}
        <div class="nosotros-grid">
          {/* Columna Imágenes */}
          <div class="nosotros-images">
            <div class="image-card-large">
              <img src="/images/nosotros-main.webp" alt="Exportadora Surberries" />
              <div class="image-card-overlay">
                <span>Trayectoria y Experiencia</span>
              </div>
            </div>
            
            <div class="image-cards-small">
              <div class="image-card-small">
                <img src="/images/proceso-1.webp" alt="Control de Calidad" />
                <div class="image-card-overlay">
                  <span>Calidad</span>
                </div>
              </div>
              <div class="image-card-small">
                <img src="/images/proceso-2.webp" alt="Almacenamiento" />
                <div class="image-card-overlay">
                  <span>Almacenamiento</span>
                </div>
              </div>
              <div class="image-card-small">
                <img src="/images/proceso-3.webp" alt="Logística" />
                <div class="image-card-overlay">
                  <span>Logística</span>
                </div>
              </div>
            </div>
          </div>
          
          {/* Columna Contenido */}
          <div class="nosotros-content">
            <div class="content-block">
              <h3>Nuestra Trayectoria</h3>
              <p class="lead">
                Somos un equipo de profesionales con más de 10 años de experiencia individual 
                en la industria de exportación de frutas y verduras congeladas.
              </p>
              <p>
                Exportadora Surberries nace como una alianza estratégica de expertos en comercio exterior, 
                logística internacional y control de calidad, uniendo nuestras trayectorias para ofrecer 
                un servicio premium desde Chile al mundo.
              </p>
            </div>
            
            <div class="pilares">
              <div class="pilar-item">
                <span class="pilar-number">01</span>
                <div class="pilar-text">
                  <h4>Calidad Certificada</h4>
                  <p>Productos bajo estándares HACCP, FDA y BRC. Certificaciones internacionales que garantizan inocuidad.</p>
                </div>
              </div>
              
              <div class="pilar-item">
                <span class="pilar-number">02</span>
                <div class="pilar-text">
                  <h4>Origen Trazable</h4>
                  <p>Relación directa con productores certificados. Conocemos cada etapa del proceso productivo.</p>
                </div>
              </div>
              
              <div class="pilar-item">
                <span class="pilar-number">03</span>
                <div class="pilar-text">
                  <h4>Logística Integral</h4>
                  <p>Cadena de frío garantizada desde origen hasta destino. Coordinación puerto-a-puerto.</p>
                </div>
              </div>
            </div>
            
            <div class="nosotros-cta">
              <h3>¿Listo para trabajar con nosotros?</h3>
              <p>Contáctanos y descubre por qué somos el partner ideal para tu negocio.</p>
              <div class="cta-buttons">
                <a href="/cotizar" class="btn btn-primary btn-lg">
                  Solicitar Cotización
                </a>
                <a href="#contacto" class="btn btn-outline btn-lg">
                  Contáctanos
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    {/* =========================================
        LIGHTBOX MODAL PARA IMÁGENES
        ========================================= */}
    <div class="lightbox-modal" id="lightboxModal">
      <div class="lightbox-overlay" id="lightboxOverlay"></div>
      <div class="lightbox-content">
        <button class="lightbox-close" id="lightboxClose">&times;</button>
        <img src="" alt="" class="lightbox-image" id="lightboxImage" />
        <div class="lightbox-caption" id="lightboxCaption"></div>
        <button class="lightbox-nav lightbox-prev" id="lightboxPrev">&#10094;</button>
        <button class="lightbox-nav lightbox-next" id="lightboxNext">&#10095;</button>
      </div>
    </div>
    
    {/* =========================================
        SECCIÓN CONTACTO
        ========================================= */}
    <section class="contacto-section" id="contacto">
      <div class="container-custom">
        {/* Header */}
        <div class="contacto-header">
          <span class="section-badge">Contacto</span>
          <h2>Hablemos de tu próximo pedido</h2>
          <p>Estamos listos para atenderte. Contáctanos y te responderemos en menos de 24 horas.</p>
        </div>
        
        <div class="contacto-grid">
          {/* Columna Izquierda - Información */}
          <div class="contacto-info">
            <div class="info-card">
              <div class="info-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              </div>
              <div class="info-content">
                <h4>Ubicación</h4>
                <p>Isabel Riquelme 506, Chillán, Chile</p>
                <p class="info-detail">Valle Central, Región Metropolitana</p>
              </div>
            </div>
            
            <div class="info-card">
              <div class="info-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
              </div>
              <div class="info-content">
                <h4>Email</h4>
                <p>contacto@exportsurberries.com</p>
                <p class="info-detail">Respondemos en menos de 24 horas</p>
              </div>
            </div>
            
            <div class="info-card">
              <div class="info-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
              </div>
              <div class="info-content">
                <h4>Teléfono / WhatsApp</h4>
                <p>+56 9 5900 8508</p>
                <p class="info-detail">Lunes a Viernes, 9:00 - 18:00</p>
              </div>
            </div>
            
            {/* Redes Sociales */}
            <div class="social-links">
              <h4>Síguenos</h4>
              <div class="social-icons">
                <a href="#" class="social-icon" aria-label="LinkedIn">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
                <a href="#" class="social-icon" aria-label="Instagram">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
          
          {/* Columna Derecha - Formulario */}
          <div class="contacto-form-wrapper">
            <form class="contacto-form" id="contactoForm" name="contacto" method="POST" data-netlify="true">
              <input type="hidden" name="form-name" value="contacto" />
              
              <div class="form-row">
                <div class="form-group">
                  <label for="contacto-nombre">Nombre *</label>
                  <input type="text" id="contacto-nombre" name="nombre" required placeholder="Tu nombre" />
                </div>
                <div class="form-group">
                  <label for="contacto-empresa">Empresa</label>
                  <input type="text" id="contacto-empresa" name="empresa" placeholder="Nombre de tu empresa" />
                </div>
              </div>
              
              <div class="form-row">
                <div class="form-group">
                  <label for="contacto-email">Email *</label>
                  <input type="email" id="contacto-email" name="email" required placeholder="tu@email.com" />
                </div>
                <div class="form-group">
                  <label for="contacto-telefono">Teléfono</label>
                  <input type="tel" id="contacto-telefono" name="telefono" placeholder="+56 9 XXXX XXXX" />
                </div>
              </div>
              
              <div class="form-group">
                <label for="contacto-mensaje">Mensaje *</label>
                <textarea id="contacto-mensaje" name="mensaje" rows="5" required placeholder="¿En qué podemos ayudarte?"></textarea>
              </div>
              
              <button type="submit" class="btn btn-primary btn-lg btn-full">
                Enviar Mensaje
              </button>
              
              <div class="form-success" id="formSuccess" style="display: none;">
                <p>✅ ¡Mensaje enviado! Te contactaremos pronto.</p>
              </div>
            </form>
          </div>
        </div>
        
        {/* Mapa de Google Maps */}
        <div class="mapa-section">
          <div class="mapa-container">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3202.796439269899!2d-72.0994611!3d-36.6072114!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9668d7d5e611004b%3A0xb0aa1eb48a731b45!2sIsabel%20Riquelme%20506%2C%20Chill%C3%A1n%2C%20%C3%91uble!5e0!3m2!1ses!2scl!4v1775700766387!5m2!1ses!2scl"
              width="100%" 
              height="450" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación Exportadora Surberries"
              class="google-map"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

  </div>
  
    <script>
    // Lightbox para imágenes de proceso - VERSIÓN CORREGIDA
    document.addEventListener('DOMContentLoaded', () => {
      const lightboxModal = document.getElementById('lightboxModal');
      const lightboxOverlay = document.getElementById('lightboxOverlay');
      const lightboxClose = document.getElementById('lightboxClose');
      const lightboxImage = document.getElementById('lightboxImage');
      const lightboxCaption = document.getElementById('lightboxCaption');
      const lightboxPrev = document.getElementById('lightboxPrev');
      const lightboxNext = document.getElementById('lightboxNext');
      
      const processImages = document.querySelectorAll('.image-card-small img');
      let currentIndex = 0;
      const images = [];
      
      // Verificar que existen los elementos
      if (!lightboxModal) {
        console.warn('Lightbox modal no encontrado');
        return;
      }
      
      // Colectar imágenes
      processImages.forEach((img, index) => {
        const caption = img.nextElementSibling?.querySelector('span')?.textContent || '';
        images.push({
          src: img.src,
          alt: img.alt,
          caption: caption
        });
        
        img.style.cursor = 'pointer';
        img.addEventListener('click', () => openLightbox(index));
      });
      
      if (images.length === 0) {
        console.warn('No se encontraron imágenes para el lightbox');
        return;
      }
      
      function openLightbox(index) {
        currentIndex = index;
        updateLightbox();
        lightboxModal.classList.add('active');
        document.body.style.overflow = 'hidden';
        console.log('Lightbox abierto, imagen:', currentIndex);
      }
      
      function closeLightbox() {
        lightboxModal.classList.remove('active');
        document.body.style.overflow = '';
        console.log('Lightbox cerrado');
      }
      
      function updateLightbox() {
        const img = images[currentIndex];
        if (lightboxImage) lightboxImage.src = img.src;
        if (lightboxImage) lightboxImage.alt = img.alt;
        if (lightboxCaption) lightboxCaption.textContent = img.caption;
      }
      
      function showPrev() {
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        updateLightbox();
      }
      
      function showNext() {
        currentIndex = (currentIndex + 1) % images.length;
        updateLightbox();
      }
      
      // Event Listeners con verificación
      if (lightboxClose) {
        lightboxClose.addEventListener('click', closeLightbox);
      }
      
      if (lightboxOverlay) {
        lightboxOverlay.addEventListener('click', closeLightbox);
      }
      
      if (lightboxPrev) {
        lightboxPrev.addEventListener('click', showPrev);
      }
      
      if (lightboxNext) {
        lightboxNext.addEventListener('click', showNext);
      }
      
      // Teclado
      document.addEventListener('keydown', (e) => {
        if (!lightboxModal.classList.contains('active')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') showPrev();
        if (e.key === 'ArrowRight') showNext();
      });
    });
  </script>

  <style>
    /* =========================================
       PRODUCTOS PREVIEW
       ========================================= */
    .productos-preview-section {
      padding: var(--section-padding);
      background: var(--color-off-white);
    }

    .section-header {
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
    }

    .section-badge {
      display: inline-block;
      padding: 0.5rem 2rem;
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      color: var(--color-white);
      border-radius: var(--radius-full);
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .section-header h2 {
      font-size: clamp(2rem, 4vw, 2.5rem);
      margin-bottom: 1rem;
      color: var(--color-gray-900);
    }

    .section-header p {
      font-size: 1.125rem;
      color: var(--color-gray-600);
      line-height: 1.7;
    }

    .products-preview {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      margin: 3rem 0;
    }

.preview-card {
  background: var(--color-white);
  padding: 2.5rem 2rem;
  border-radius: var(--radius-xl);
  text-align: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  /* ✅ Agregar estas 3 líneas para centrar contenido: */
  display: flex;
  flex-direction: column;
  align-items: center;
}

    .preview-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    }

    .preview-image {
  width: 160px;
  height: 160px;
  object-fit: contain;
  /* ✅ Cambiar margin-bottom por margin auto para centrado vertical: */
  margin: 0 auto 1.25rem;
  display: block;
}

    .preview-card h3 {
      font-size: 1.25rem;
      color: var(--color-gray-900);
      margin: 0;
      font-weight: 600;
    }

    .section-cta-centered {
      text-align: center;
      margin-top: 3.5rem;
    }

    /* =========================================
       NOSOTROS SECTION
       ========================================= */
    .nosotros-section {
      padding: var(--section-padding);
      background: var(--color-white);
    }

    .nosotros-header {
      text-align: center;
      max-width: 900px;
      margin: 0 auto 4rem;
    }

    .nosotros-header h2 {
      font-size: clamp(2rem, 4vw, 2.75rem);
      margin-bottom: 1rem;
      color: var(--color-gray-900);
      line-height: 1.2;
    }

    .nosotros-subtitle {
      font-size: 1.25rem;
      color: var(--color-gray-600);
      line-height: 1.7;
      max-width: 700px;
      margin: 0 auto;
    }

    /* Stats Cards */
    .nosotros-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-bottom: 5rem;
      max-width: 1000px;
      margin-left: auto;
      margin-right: auto;
    }

    .stat-card {
      background: var(--color-white);
      border: 2px solid var(--color-gray-100);
      border-radius: var(--radius-xl);
      padding: 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      transition: all 0.3s ease;
    }

    .stat-card:hover {
      border-color: var(--color-primary);
      box-shadow: 0 8px 30px rgba(184, 26, 56, 0.1);
      transform: translateY(-5px);
    }

    .stat-icon {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      border-radius: var(--radius-lg);
      display: flex;
      align-items: center;
