---
// Página de Mantenimiento - NO usa Layout
export const prerender = false;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sitio en Mantenimiento - Exportadora Sur Berries</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      text-align: center;
      color: #333;
    }
    .container {
      max-width: 600px;
      background: white;
      padding: 3rem;
      border-radius: 15px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.15);
    }
    .logo {
      max-width: 180px;
      margin-bottom: 2rem;
    }
    h1 {
      color: #1e3c2a;
      font-size: 1.75rem;
      margin-bottom: 1rem;
    }
    p {
      color: #666;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }
    .contact-box {
      background: #f8f9fa;
      padding: 1.5rem;
      border-radius: 10px;
      margin: 1.5rem 0;
      text-align: left;
    }
    .contact-box strong {
      color: #1e3c2a;
      display: block;
      margin-bottom: 0.5rem;
    }
    .contact-box p {
      margin: 0.25rem 0;
      font-size: 0.95rem;
    }
    .footer {
      margin-top: 2rem;
      font-size: 0.85rem;
      color: #888;
    }
    .badge {
      display: inline-block;
      background: #ffc107;
      color: #856404;
      padding: 0.3rem 0.75rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <img src="/images/logo-surberries.png" alt="Exportadora Sur Berries" class="logo" />
    <span class="badge">⚠️ Mantenimiento Programado</span>
    <h1>Sitio en Mantenimiento</h1>
    <p>
      Este sitio se encuentra temporalmente en mantenimiento programado.
    </p>
    
    <div class="contact-box">
      <strong>Para consultas comerciales, favor contactar a:</strong>
      <p>📧 contacto@exportsurberries.com</p>
      <p>📱 +56 9 5900 8508</p>
    </div>
    
    <p class="footer">
      Disculpe las molestias.
    </p>
  </div>
</body>
</html>