      </div>

      {/* CTA Final */}
      <div class="productos-cta">
        <h2>¿Necesitas una cotización personalizada?</h2>
        <p>Contáctanos y te enviaremos una propuesta adaptada a tus necesidades.</p>
        <div class="cta-buttons">
          <a href="/cotizar" class="btn btn-primary btn-lg">
            Solicitar Cotización
          </a>
          <a href="https://wa.me/56959008508" class="btn btn-secondary btn-lg" target="_blank" rel="noopener noreferrer">
            WhatsApp Directo
          </a>
        </div>
      </div>
    </div>
  </main>

  <style>
    .productos-page {
      padding: 10rem 0 4rem;
      background: var(--color-off-white);
      min-height: 100vh;
    }

    .page-header {
      text-align: center;
      max-width: 800px;
      margin: 0 auto 4rem;
    }

    .page-header h1 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: var(--color-gray-900);
    }

    .page-header p {
      font-size: 1.125rem;
      color: var(--color-gray-600);
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .product-card {
      background: var(--color-white);
      border-radius: var(--radius-xl);
      overflow: hidden;
      box-shadow: var(--shadow-md);
      transition: all var(--transition-base);
      display: flex;
      flex-direction: column;
    }

    .product-card:hover {
      transform: translateY(-10px);
      box-shadow: var(--shadow-2xl);
    }

    .product-image-wrapper {
      position: relative;
      height: 300px;
      overflow: hidden;
      background: linear-gradient(135deg, var(--color-gray-100) 0%, var(--color-gray-200) 100%);
    }

.product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;  /* ✅ Centrar la imagen */
  transition: transform var(--transition-base);
}

    .product-card:hover .product-image {
      transform: scale(1.05);
    }

    .season-badge {
      position: absolute;
      top: 1rem;
      right: 1rem;
      padding: 0.5rem 1rem;
      border-radius: var(--radius-full);
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--color-white);
      z-index: 1;
    }

    .season-badge.available {
      background: var(--color-secondary);
    }

    .season-badge.limited {
      background: var(--color-primary);
    }

    .product-info {
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      flex: 1;
    }

    .product-info h3 {
      font-size: 1.5rem;
      color: var(--color-gray-900);
      margin: 0;
    }

    .product-subtitle {
      font-size: 1rem;
      color: var(--color-gray-500);
      margin: 0;
      font-weight: 500;
    }

    .product-specs {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .product-specs li {
      font-size: 0.95rem;
      color: var(--color-gray-600);
    }

    .btn-cotizar {
      margin-top: auto;
      width: 100%;
      justify-content: center;
    }

    /* Card "Otros Productos" - Estilo diferente */
    .product-card-others {
      background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
      color: var(--color-white);
    }

    .product-card-others .product-info h3,
    .product-card-others .product-subtitle,
    .product-card-others .product-specs li {
      color: var(--color-white);
    }

    .product-card-others .btn-outline {
      border-color: var(--color-white);
      color: var(--color-white);
    }

    .product-card-others .btn-outline:hover {
      background: var(--color-white);
      color: var(--color-primary);
    }

    /* CTA Final */
    .productos-cta {
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      color: var(--color-white);
      padding: 4rem 3rem;
      border-radius: var(--radius-xl);
      text-align: center;
      margin-top: 4rem;
    }

    .productos-cta h2 {
      font-size: 2rem;
      margin-bottom: 1rem;
      color: var(--color-white);
    }

    .productos-cta p {
      font-size: 1.125rem;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 2rem;
    }

    .cta-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .products-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .productos-page {
        padding: 8rem 0 3rem;
      }

      .products-grid {
        grid-template-columns: 1fr;
      }

      .page-header h1 {
        font-size: 2rem;
      }

      .productos-cta {
        padding: 3rem 2rem;
      }

      .cta-buttons {
        flex-direction: column;
      }

      .cta-buttons .btn {
        width: 100%;
      }
    }
  </style>

</Layout>