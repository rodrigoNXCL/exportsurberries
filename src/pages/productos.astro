              <li>✓ Cajas 10kg x 1</li>
              <li>✓ Calibre: S / M / L</li>
              <li>✓ Temporada: Oct - Dic</li>
            </ul>
            <div class="product-buttons">
              <a href="/cotizar?producto=esparrago-iqf" class="btn btn-primary btn-cotizar">
                Cotizar Espárragos
              </a>
              <a href="/fichas/esparrago-iqf.pdf" target="_blank" class="btn btn-outline btn-ficha">
                📄 Ficha Técnica
              </a>
            </div>
          </div>
        </article>

        {/* Producto 7: Otros Productos */}
        <article class="product-card product-card-others" data-producto="otros">
          <div class="product-image-wrapper">
            <img
              src="/images/products/otros-productos.webp"
              alt="Otros Productos Congelados - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
          </div>
          <div class="product-info">
            <h3>¿Buscas otro producto?</h3>
            <p class="product-subtitle">Tenemos más opciones</p>
            <ul class="product-specs">
              <li>🫐 Moras IQF</li>
              <li>🍓 Mix de Berries</li>
              <li>🥬 Espinaca IQF</li>
              <li>🥦 Brócoli IQF</li>
            </ul>
            <a href="/cotizar" class="btn btn-outline btn-cotizar">
              Consultar Disponibilidad
            </a>
          </div>
        </article>

        {/* Producto 8: Hongo Boletus */}
        <article class="product-card" data-producto="boletus">
          <div class="product-image-wrapper">
            <img
              src="/images/products/boletus-iqf.webp"
              alt="Hongo Boletus IQF Congelado - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          <div class="product-info">
            <h3>Hongo Boletus IQF</h3>
            <p class="product-subtitle">Silvestre</p>
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 10kg</li>
              <li>✓ Grado: A / B</li>
              <li>✓ Temporada: Mar - Jun</li>
            </ul>
            <div class="product-buttons">
              <a href="/cotizar?producto=boletus-iqf" class="btn btn-primary btn-cotizar">
                Cotizar Boletus
              </a>
              <a href="/fichas/boletus-iqf.pdf" target="_blank" class="btn btn-outline btn-ficha">
                📄 Ficha Técnica
              </a>
            </div>
          </div>
        </article>

        {/* Producto 9: Uva IQF */}
        <article class="product-card" data-producto="uva">
          <div class="product-image-wrapper">
            <img
              src="/images/products/uva-iqf.webp"
              alt="Uva IQF Congelada - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          <div class="product-info">
            <h3>Uva IQF</h3>
            <p class="product-subtitle">Sin Semillas / Con Semillas</p>
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 10kg</li>
              <li>✓ Variedades: Red / Green / Black</li>
              <li>✓ Temporada: Ene - May</li>
            </ul>
            <div class="product-buttons">
              <a href="/cotizar?producto=uva-iqf" class="btn btn-primary btn-cotizar">
                Cotizar Uva
              </a>
              <a href="/fichas/uva-iqf.pdf" target="_blank" class="btn btn-outline btn-ficha">
                📄 Ficha Técnica
              </a>
            </div>
          </div>
        </article>

        {/* Producto 10: Castañas IQF */}
        <article class="product-card" data-producto="castana">
          <div class="product-image-wrapper">
            <img
              src="/images/products/castana-iqf.webp"
              alt="Castañas IQF Congeladas - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          <div class="product-info">
            <h3>Castañas IQF</h3>
            <p class="product-subtitle">Peladas / Enteras</p>
            <ul class="product-specs">
