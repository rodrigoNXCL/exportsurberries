---
// Página Productos - Exportadora Surberries
// Catálogo de productos congelados IQF
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Productos" 
  description="Frutillas, arándanos, frambuesas y espárragos congelados IQF de la más alta calidad. Exportación desde Chile." 
  lang="es"
>
  <main class="productos-page">
    <div class="container-custom">
      {/* Header de la página */}
      <div class="page-header">
        <h1>Nuestros Productos</h1>
        <p>Frutas y vegetales congeladas IQF (Individual Quick Frozen) de la más alta calidad, cultivadas en el valle central de Chile.</p>
      </div>

      {/* Grid de productos */}
      <div class="products-grid">
        {/* Producto 1: Arándanos */}
        <article class="product-card" data-producto="arandano">
          <div class="product-image-wrapper">
            <img
              src="/images/products/arandano-iqf.webp"
              alt="Arándanos IQF Congelados - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          <div class="product-info">
            <h3>Arándanos IQF</h3>
            <p class="product-subtitle">Calibre 10 Up</p>
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 30lbs / 13.61</li>
              <li>✓ Variedades: Legacy, O'Neal, Brigitta, Ochlockonee</li>
              <li>✓ Temporada: Nov - Abr</li>
            </ul>
            <div class="product-buttons">
              <a href="/cotizar?producto=arandano-iqf" class="btn btn-primary btn-cotizar">
                Cotizar Arándanos
              </a>
              <a href="/fichas/arandano-iqf.pdf" target="_blank" class="btn btn-outline btn-ficha">
                📄 Ficha Técnica
              </a>
            </div>
          </div>
        </article>

        {/* Producto 2: Frambuesas */}
        <article class="product-card" data-producto="frambuesa">
          <div class="product-image-wrapper">
            <img
              src="/images/products/frambuesa-iqf.webp"
              alt="Frambuesas IQF Congeladas - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          <div class="product-info">
            <h3>Frambuesas IQF</h3>
            <p class="product-subtitle">Summer / Fall</p>
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 10kg / 2.5kg</li>
              <li>✓ Alta Calidad</li>
              <li>✓ Temporada: Dic - Mar</li>
            </ul>
            <div class="product-buttons">
              <a href="/cotizar?producto=frambuesa-iqf" class="btn btn-primary btn-cotizar">
                Cotizar Frambuesas
              </a>
              <a href="/fichas/frambuesa-iqf.pdf" target="_blank" class="btn btn-outline btn-ficha">
                📄 Ficha Técnica
              </a>
            </div>
          </div>
        </article>

        {/* Producto 3: Mora */}
        <article class="product-card" data-producto="mora">
          <div class="product-image-wrapper">
            <img
              src="/images/products/mora-iqf.webp"
              alt="Mora IQF Congelada - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          <div class="product-info">
            <h3>Mora IQF</h3>
            <p class="product-subtitle">Alta Calidad</p>
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 30lbs / 13.61</li>
              <li>✓ Alta Calidad</li>
              <li>✓ Temporada: Dic - Mar</li>
            </ul>
            <div class="product-buttons">
              <a href="/cotizar?producto=mora-iqf" class="btn btn-primary btn-cotizar">
                Cotizar Mora
              </a>
              <a href="/fichas/mora-iqf.pdf" target="_blank" class="btn btn-outline btn-ficha">
                📄 Ficha Técnica
              </a>
            </div>
          </div>
        </article>

        {/* Producto 4: Cereza */}
        <article class="product-card" data-producto="cereza">
          <div class="product-image-wrapper">
            <img
              src="/images/products/cereza-iqf.webp"
              alt="Cereza IQF Congelada - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          <div class="product-info">
            <h3>Cereza IQF</h3>
            <p class="product-subtitle">Alta Calidad / Sin Carozo</p>
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 10kg</li>
              <li>✓ Variedades: Bing / Lapins</li>
              <li>✓ Temporada: Dic - Feb</li>
            </ul>
            <div class="product-buttons">
              <a href="/cotizar?producto=cereza-iqf" class="btn btn-primary btn-cotizar">
                Cotizar Cereza
              </a>
              <a href="/fichas/cereza-iqf.pdf" target="_blank" class="btn btn-outline btn-ficha">
                📄 Ficha Técnica
              </a>
            </div>
          </div>
        </article>

        {/* Producto 5: Frutillas */}
        <article class="product-card" data-producto="frutilla">
          <div class="product-image-wrapper">
            <img
              src="/images/products/frutilla-iqf.webp"
              alt="Frutillas IQF Congeladas - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          <div class="product-info">
            <h3>Frutillas IQF</h3>
            <p class="product-subtitle">Alta Calidad</p>
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 30lbs / 13.61</li>
              <li>✓ Brix: 8-10°</li>
              <li>✓ Temporada: Nov - Mar</li>
            </ul>
            <div class="product-buttons">
              <a href="/cotizar?producto=frutilla-iqf" class="btn btn-primary btn-cotizar">
