              <li>✓ Temporada: Abr - Jul</li>
            </ul>
            <div class="product-buttons">
              <a href="/cotizar?producto=castana-iqf" class="btn btn-primary btn-cotizar">
                Cotizar Castañas
              </a>
              <a href="/fichas/castana-iqf.pdf" target="_blank" class="btn btn-outline btn-ficha">
                📄 Ficha Técnica
              </a>
            </div>
          </div>
        </article>

        {/* Producto 11: Kiwi IQF */}
        <article class="product-card" data-producto="kiwi">
          <div class="product-image-wrapper">
            <img
              src="/images/products/kiwi-iqf.webp"
              alt="Kiwi IQF Congelado - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          <div class="product-info">
            <h3>Kiwi IQF</h3>
            <p class="product-subtitle">Verde / Dorado</p>
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 10kg</li>
              <li>✓ Corte: Rodajas / Cubos</li>
              <li>✓ Temporada: May - Ago</li>
            </ul>
            <div class="product-buttons">
              <a href="/cotizar?producto=kiwi-iqf" class="btn btn-primary btn-cotizar">
                Cotizar Kiwi
