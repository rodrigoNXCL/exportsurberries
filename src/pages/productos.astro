---
// Página Productos - Exportadora Surberries
// Catálogo de productos congelados IQF
import Layout from '../layouts/Layout.astro';

---

<Layout title="Productos" description="Frutillas, arándanos, frambuesas y espárragos congelados IQF de la más alta calidad. Exportación desde Chile." lang="es">
  
  
  
  <main class="productos-page">
    <div class="container-custom">
      {/* Header de la página */}
      <div class="page-header">
        <h1>Nuestros Productos</h1>
        <p>Frutas y verduras congeladas IQF (Individual Quick Frozen) de la más alta calidad, cultivadas en el valle central de Chile.</p>
      </div>

      {/* Grid de productos */}
      <div class="products-grid">
        {/* Producto 1: Frutillas */}
        <article class="product-card" data-producto="frutilla">
          <div class="product-image-wrapper">
            <img 
              src="/images/products/frutilla-iqf.webp" 
              alt="Frutillas IQF Congeladas - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          
          <div class="product-info">
            <h3>Frutillas IQF</h3>
            <p class="product-subtitle">Premium Grade A</p>
            
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 30lbs / 13.61</li>
              <li>✓ Brix: 8-10°</li>
              <li>✓ Temporada: Nov - Mar</li>
            </ul>
            
            <a href="/cotizar?producto=frutilla-iqf" class="btn btn-primary btn-cotizar">
              Cotizar Frutillas
            </a>
          </div>
        </article>

        {/* Producto 2: Arándanos */}
        <article class="product-card" data-producto="arandano">
          <div class="product-image-wrapper">
            <img 
              src="/images/products/arandano-iqf.webp" 
              alt="Arándanos IQF Congelados - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          
          <div class="product-info">
            <h3>Arándanos IQF</h3>
            <p class="product-subtitle">Calibre 14-18mm</p>
            
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 30lbs / 13.61</li>
              <li>✓ Variedades: Legacy, O'Neal, Brigitta, Ochlockonee</li>
              <li>✓ Temporada: Oct - Feb</li>
            </ul>
            
            <a href="/cotizar?producto=arandano-iqf" class="btn btn-primary btn-cotizar">
              Cotizar Arándanos
            </a>
          </div>
        </article>

        {/* Producto 3: Frambuesas */}
        <article class="product-card" data-producto="frambuesa">
          <div class="product-image-wrapper">
            <img 
              src="/images/products/frambuesa-iqf.webp" 
              alt="Frambuesas IQF Congeladas - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge available">Disponible</span>
          </div>
          
          <div class="product-info">
            <h3>Frambuesas IQF</h3>
            <p class="product-subtitle">Summer / Fall</p>
            
            <ul class="product-specs">
              <li>✓ IQF (Congelado Individual)</li>
              <li>✓ Cajas 10kg / 2.5kg</li>
              <li>✓ Grado Premium</li>
              <li>✓ Temporada: Dic - Mar</li>
            </ul>
            
            <a href="/cotizar?producto=frambuesa-iqf" class="btn btn-primary btn-cotizar">
              Cotizar Frambuesas
            </a>
          </div>
        </article>

        {/* Producto 4: Espárragos */}
        <article class="product-card" data-producto="esparrago">
          <div class="product-image-wrapper">
            <img 
              src="/images/products/esparrago-iqf.webp" 
              alt="Espárragos IQF Congelados - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
            <span class="season-badge limited">Temporada Cerrada</span>
          </div>
          
          <div class="product-info">
            <h3>Espárragos IQF</h3>
            <p class="product-subtitle">Verdes</p>
            
            <ul class="product-specs">
              <li>✓ IQF (Puntas / Enteros)</li>
              <li>✓ Cajas 10kg x 1</li>
              <li>✓ Calibre: S / M / L</li>
              <li>✓ Temporada: Oct - Dic</li>
            </ul>
            
            <a href="/cotizar?producto=esparrago-iqf" class="btn btn-primary btn-cotizar">
              Cotizar Espárragos
            </a>
          </div>
        </article>

        {/* Producto 5: Otros Productos */}
        <article class="product-card product-card-others" data-producto="otros">
          <div class="product-image-wrapper">
            <img 
              src="/images/products/otros-productos.webp" 
              alt="Otros Productos Congelados - Exportadora Surberries"
              width="800"
              height="800"
              loading="lazy"
              class="product-image"
            />
          </div>
          
          <div class="product-info">
            <h3>¿Buscas otro producto?</h3>
            <p class="product-subtitle">Tenemos más opciones</p>
            
            <ul class="product-specs">
              <li>🫐 Moras IQF</li>
              <li>🍓 Mix de Berries</li>
              <li>🥬 Espinaca IQF</li>
              <li>🥦 Brócoli IQF</li>
            </ul>
            
            <a href="/cotizar" class="btn btn-outline btn-cotizar">
              Consultar Disponibilidad
            </a>
          </div>
        </article>

{/* Producto 6: Mora */}
<article class="product-card" data-producto="mora">
